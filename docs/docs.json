                  "reference/components/file-tree"
                ]
              },
              {
                "group": "Text helpers",
                "pages": [
                  "reference/components/icon",
                  "reference/components/kbd",
                  "reference/components/badge",
                  "reference/components/tooltip",
                  "reference/components/expandable",
                  "reference/components/glossary-term"
                ]
              }
            ]
          },
          {
            "group": "Markdown & MDX",
            "pages": [
              "reference/markdown/index",
              "reference/markdown/text-and-headings",
              "reference/markdown/lists-tables",
              "reference/markdown/code",
              "reference/markdown/links-images",
              "reference/markdown/mdx",
              "reference/markdown/latex",
              "reference/markdown/embeds"
            ]
          }
        ]
      },
      {
        "tab": "Tutorials",
        "groups": [
          {
            "group": "Step-by-step",
            "pages": [
              "tutorials/first-docs-site",
              "tutorials/api-reference",
              "tutorials/customize-theme"
            ]
          }
        ]
      },
      {
        "tab": "Architecture",
        "groups": [
          {
            "group": "Internals",
            "pages": [
              "architecture/overview",
              "architecture/manifest",
              "architecture/vite-plugin",
              "architecture/runtime"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/tanglydocs/tangly",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [{ "label": "GitHub", "href": "https://github.com/tanglydocs/tangly" }],
    "primary": {
      "type": "button",
      "label": "Star on GitHub",
      "href": "https://github.com/tanglydocs/tangly"
    }
  }

            ]
          },
          {
            "group": "AI agents",
            "pages": [
              "guides/ai-agents/index",
              "guides/ai-agents/skills",
              "guides/ai-agents/cursor-and-others",
              "guides/ai-agents/llms-txt",
              "guides/ai-agents/markdown-for-agents",
              "guides/ai-agents/conventions"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/common-errors",
              "troubleshooting/faq"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "reference/cli/dev",
              "reference/cli/build",
              "reference/cli/preview",
              "reference/cli/check",
              "reference/cli/init",
              "reference/cli/migrate",
              "reference/cli/add",
              "reference/cli/eject"
            ]
          },
          {
            "group": "Schema",
            "pages": [
              "reference/schema/docs-json",
              "reference/schema/navigation",
              "reference/schema/colors",
              "reference/schema/logo-favicon",
              "reference/schema/footer-navbar",
              "reference/schema/api",
              "reference/schema/analytics",
              "reference/schema/seo",
              "reference/schema/redirects",
              "reference/schema/errors-banner",
              "reference/schema/contextual",
              "reference/schema/themes",
              "reference/schema/icons",
              "reference/schema/fonts-styling",
              "reference/schema/integrations"
            ]
          },
          {
            "group": "Frontmatter",
            "pages": ["reference/schema/frontmatter"]
          },
          {
            "group": "Components",
            "pages": [
              "reference/components/index",
              {
                "group": "Cards & layout",
                "pages": [
                  "reference/components/card",
                  "reference/components/card-group",
                  "reference/components/columns"
                ]
              },
              {

{
  "$schema": "../packages/schema/dist/docs.json",
  "name": "Tangly",
  "description": "Self-hosted, open-source documentation framework.",
  "theme": "tang",
  "colors": {
    "primary": "#EA580C",
    "light": "#F97316",
    "dark": "#C2410C"
  },
  "favicon": "/images/favicon.ico",
  "logo": {
    "light": "/images/tangly-logo.png",
    "dark": "/images/tangly-logo-light.png",
    "href": "/"
  },
  "appearance": {
    "default": "system",
    "readingTime": true,
    "readingProgress": true
  },
  "footer": {
    "lastUpdated": true,
    "repo": "https://github.com/tanglydocs/tangly",
    "editUrl": "https://github.com/tanglydocs/tangly/edit/main/docs/{path}",
    "socials": {
      "github": "https://github.com/tanglydocs/tangly"
    }
  },
  "banner": {
    "id": "v02-launch",
    "type": "info",
    "dismissible": true,
    "content": "Tangly v0.2 ships richer code blocks, page chrome, and more — <a href=\"/changelog\">see what's new</a>"
  },
  "redirects": [
    { "source": "/guides/migrate-from-mintlify", "destination": "/guides/migration/from-mintlify", "permanent": true },
    { "source": "/guides/configuration", "destination": "/guides/customization/configuration", "permanent": true },
    { "source": "/guides/themes", "destination": "/guides/themes/index", "permanent": true },
    { "source": "/guides/components", "destination": "/guides/customization/components", "permanent": true },
    { "source": "/guides/custom-components", "destination": "/guides/customization/custom-components", "permanent": true },
    { "source": "/guides/custom-templates", "destination": "/guides/customization/custom-templates", "permanent": true },
    { "source": "/guides/search", "destination": "/guides/customization/search", "permanent": true },
    { "source": "/guides/code-blocks", "destination": "/guides/authoring/code-blocks", "permanent": true },
    { "source": "/guides/announcement", "destination": "/guides/authoring/announcement", "permanent": true },
    { "source": "/guides/drafts", "destination": "/guides/authoring/drafts", "permanent": true },
    { "source": "/guides/embedded-blocks", "destination": "/guides/authoring/embedded-blocks", "permanent": true },
    { "source": "/guides/glossary", "destination": "/guides/authoring/glossary", "permanent": true },
    { "source": "/guides/navigation", "destination": "/guides/authoring/navigation", "permanent": true },
    { "source": "/guides/openapi", "destination": "/guides/authoring/openapi", "permanent": true },
    { "source": "/guides/static-assets", "destination": "/guides/deploying/static-assets", "permanent": true },
    { "source": "/guides/subpath-hosting", "destination": "/guides/deploying/subpath-hosting", "permanent": true },
    { "source": "/guides/deploying", "destination": "/guides/deploying/index", "permanent": true },
    { "source": "/reference/components/callouts", "destination": "/reference/components/note", "permanent": true },
    { "source": "/reference/components/cards", "destination": "/reference/components/card", "permanent": true },
    { "source": "/reference/components/code", "destination": "/reference/components/code-group", "permanent": true },
    { "source": "/reference/components/tabs-and-steps", "destination": "/reference/components/tabs", "permanent": true },
    { "source": "/reference/components/layout", "destination": "/reference/components/frame", "permanent": true },
    { "source": "/reference/components/api", "destination": "/reference/components/param-field", "permanent": true },
    { "source": "/reference/components/media", "destination": "/reference/components/video", "permanent": true }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Authoring",
            "pages": [
              "guides/authoring/pages",
              "guides/authoring/navigation",
              "guides/authoring/code-blocks",
              "guides/authoring/openapi",
              "guides/authoring/drafts",
              "guides/authoring/embedded-blocks",
              "guides/authoring/glossary",
              "guides/authoring/announcement"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "guides/customization/configuration",
              "guides/customization/components",
              "guides/customization/custom-components",
              "guides/customization/custom-templates",
              "guides/customization/search"
            ]
          },
          {
            "group": "Themes",
            "pages": [
              "guides/themes/index",
              "guides/themes/tang",
              "guides/themes/pith",
              "guides/themes/pip",
              "guides/themes/readable",
              "guides/themes/geist",
              "guides/themes/aliases",
              "guides/themes/customizing"
            ]
          },
          {
            "group": "Deploying",
            "pages": [
              "guides/deploying/index",
              "guides/deploying/subpath-hosting",
              "guides/deploying/static-assets"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "guides/migration/from-mintlify",

                  "reference/components/tab",
                  "reference/components/steps",
                  "reference/components/step"
                ]
              },
              {
                "group": "Accordion",
                "pages": [
                  "reference/components/accordion",
                  "reference/components/accordion-group"
                ]
              },
              {
                "group": "Code",
                "pages": [
                  "reference/components/code-group",
                  "reference/components/snippet",
                  "reference/components/package-manager"
                ]
              },
              {
                "group": "API",
                "pages": [
                  "reference/components/param-field",
                  "reference/components/response-field",

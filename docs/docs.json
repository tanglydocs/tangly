{
  "$schema": "../packages/schema/dist/docs.json",
  "name": "Tangly",
  "description": "Self-hosted, open-source documentation framework.",
  "theme": "tang",
  "colors": {
    "primary": "#EA580C",
    "light": "#F97316",
    "dark": "#C2410C"
  },
  "favicon": "/images/favicon.ico",
  "logo": {
    "light": "/images/tangly-logo.png",
    "dark": "/images/tangly-logo-light.png",
    "href": "/"
  },
  "appearance": {
    "default": "system",
    "readingTime": true,
    "readingProgress": true
  },
  "footer": {
    "lastUpdated": true,
    "repo": "https://github.com/tanglydocs/tangly",
    "editUrl": "https://github.com/tanglydocs/tangly/edit/main/docs/{path}",
    "socials": {
      "github": "https://github.com/tanglydocs/tangly"
    }
  },
  "banner": {
    "id": "v02-launch",
    "type": "info",
    "dismissible": true,
    "content": "Tangly v0.2 ships richer code blocks, page chrome, and more — <a href=\"/changelog\">see what's new</a>"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Core",
            "pages": [
              "guides/configuration",
              "guides/navigation",
              "guides/components",
              "guides/themes",
              "guides/openapi",
              "guides/search",
              "guides/glossary"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "guides/code-blocks",
              "guides/announcement",
              "guides/custom-components",
              "guides/custom-templates",
              "guides/drafts",
              "guides/embedded-blocks"
            ]
          },
          {
            "group": "Deploying",
            "pages": ["guides/deploying", "guides/subpath-hosting", "guides/static-assets"]
          },
          {
            "group": "Migration",
            "pages": ["guides/migrate-from-mintlify"]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "reference/cli/dev",
              "reference/cli/build",
              "reference/cli/preview",
              "reference/cli/check",
              "reference/cli/init",
              "reference/cli/migrate",
              "reference/cli/add",
              "reference/cli/eject"
            ]
          },
          {
            "group": "Schema",
            "pages": [
              "reference/schema/docs-json",
              "reference/schema/frontmatter",
              "reference/schema/themes",
              "reference/schema/colors",
              "reference/schema/icons"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "reference/components/callouts",
              "reference/components/cards",
              "reference/components/tabs-and-steps",
              "reference/components/code",
              "reference/components/layout",
              "reference/components/api",
              "reference/components/media"
            ]
          }
        ]
      },
      {
        "tab": "Architecture",
        "groups": [
          {
            "group": "Internals",
            "pages": [
              "architecture/overview",
              "architecture/manifest",
              "architecture/vite-plugin",
              "architecture/runtime"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/tanglydocs/tangly",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [{ "label": "GitHub", "href": "https://github.com/tanglydocs/tangly" }],
    "primary": {
      "type": "button",
      "label": "Star on GitHub",
      "href": "https://github.com/tanglydocs/tangly"
    }
  }
}

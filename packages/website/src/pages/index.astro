---
import "~/styles/globals.css";
import Hero from "~/sections/hero.astro";
import QuickExample from "~/sections/quick-example.astro";
import Components from "~/sections/components.astro";
import TheRest from "~/sections/the-rest.astro";
import Themes from "~/sections/themes.astro";
import OpenApi from "~/sections/openapi.astro";
import Deploy from "~/sections/deploy.astro";
import Footer from "~/sections/footer.astro";
import Nav from "~/sections/nav.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/brand/favicon.ico" />
    <link rel="canonical" href="https://tangly.dev/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="image"
      href="/brand/tangly-icon-1024.webp"
      type="image/webp"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Source+Serif+4:wght@400;500;600&family=EB+Garamond:wght@400;500&display=swap"
    />
    <title>Tangly — open-source documentation, self-hosted</title>
    <meta
      name="description"
      content="Tangly is an open-source docs framework. Markdown becomes a fast, themed, deployable docs site. No proprietary backend, no monthly bill."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tangly.dev/" />
    <meta property="og:title" content="Tangly — open-source documentation, self-hosted" />
    <meta
      property="og:description"
      content="Open-source docs framework. Folder of Markdown into a fast, themed, deployable docs site. No proprietary backend, no monthly bill."
    />
    <meta property="og:image" content="https://tangly.dev/brand/tangly-icon-1024.png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:site_name" content="Tangly" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Tangly — open-source documentation, self-hosted" />
    <meta
      name="twitter:description"
      content="Open-source docs framework. Folder of Markdown into a fast, themed, deployable docs site."
    />
    <meta name="twitter:image" content="https://tangly.dev/brand/tangly-icon-1024.png" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded focus:bg-ink focus:px-3 focus:py-2 focus:font-sans focus:text-[13px] focus:text-paper"
      >Skip to content</a>
    <Nav />
    <main id="main">
      <Hero />
      <QuickExample />
      <Components />
      <TheRest />
      <Themes />
      <OpenApi />
      <Deploy />
    </main>
    <Footer />
  </body>
</html>

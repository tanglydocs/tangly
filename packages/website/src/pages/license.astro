---
import "~/styles/globals.css";
import Nav from "~/sections/nav.astro";
import Footer from "~/sections/footer.astro";
import license from "../../../../LICENSE?raw";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/brand/favicon.ico" />
    <link rel="canonical" href="https://tangly.dev/license" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />
    <title>MIT License — Tangly open-source documentation framework</title>
    <meta
      name="description"
      content="Tangly is released under the MIT License. Build commercial products, fork, ship on customer infrastructure. No royalties, no permission needed."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tangly.dev/license" />
    <meta property="og:title" content="MIT License — Tangly" />
    <meta
      property="og:description"
      content="Tangly is released under the MIT License. Build commercial products, fork, ship on customer infrastructure. No royalties, no permission needed."
    />
    <meta property="og:image" content="https://tangly.dev/brand/og-card.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Tangly — open-source documentation, self-hosted" />
    <meta property="og:site_name" content="Tangly" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="MIT License — Tangly" />
    <meta
      name="twitter:description"
      content="Tangly is released under the MIT License."
    />
    <meta name="twitter:image" content="https://tangly.dev/brand/og-card.png" />
  </head>
  <body class="bg-paper text-ink">
    <Nav />

    <main class="mx-auto max-w-[760px] px-10 pb-24 pt-20">
      <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-tang-700">
        License
      </div>
      <h1
        class="mt-3 flex flex-col font-sans text-[44px] font-extrabold leading-[1.05] tracking-[-0.025em]"
      >
        <span class="text-ink">MIT.</span>
        <span class="text-tang-700">Use it.</span>
      </h1>

      <pre
        class="mt-10 overflow-x-auto whitespace-pre-wrap rounded-xl border border-line-light bg-paper p-7 font-mono text-[12.5px] leading-[20px] text-line-dark"
      >{license}</pre>

      <p class="mt-6 font-sans text-[13px] text-mute">
        Source: <a
          href="https://github.com/tanglydocs/tangly/blob/main/LICENSE"
          class="text-ink underline decoration-line-light underline-offset-2 hover:decoration-tang-600"
          >LICENSE in the repo</a
        >.
      </p>
    </main>

    <Footer />
  </body>
</html>

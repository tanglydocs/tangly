---
import { Check, Copy } from "lucide-astro";
---

<section class="relative overflow-hidden bg-paper">
  <!-- decorative tang glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-[180px] -top-[160px] h-[460px] w-[460px] rounded-full"
    style="background: radial-gradient(circle at center, rgba(234,88,12,0.10) 0%, rgba(234,88,12,0.03) 45%, rgba(234,88,12,0) 70%);"
  >
  </div>

  <!-- decorative grid -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-50"
    style="background-image: linear-gradient(to right, rgba(31,31,35,0.025) 1px, transparent 1px), linear-gradient(to bottom, rgba(31,31,35,0.025) 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <!-- decorative Möbius mark -->
  <img
    aria-hidden="true"
    src="/brand/tangly-icon-1024.webp"
    alt=""
    width="360"
    height="360"
    fetchpriority="high"
    class="pointer-events-none absolute -right-[80px] top-16 h-[360px] w-[360px] rotate-[-8deg] opacity-[0.09]"
  />

  <div
    class="relative z-10 mx-auto flex max-w-[1200px] flex-col gap-10 px-10 pb-20 pt-24"
  >
    <div class="flex max-w-[860px] flex-col gap-6">
      <h1 class="flex flex-col font-sans font-extrabold tracking-[-0.035em]">
        <span class="text-[88px] leading-[0.95] text-ink"
          >Open-source<br />documentation,</span>
        <span
          class="text-[88px] leading-[0.95]"
          style="background: linear-gradient(135deg, #F97316 0%, #C2410C 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; color: transparent;"
        >self-hosted.</span>
      </h1>
      <p class="max-w-[560px] font-sans text-[17px] leading-[26px] text-mute">
        Tangly turns a folder of Markdown into a fast, themed, deployable docs
        site. No proprietary backend, no monthly bill — just a static binary
        and your repo.
      </p>
    </div>

    <div class="flex items-center gap-3">
      <div
        class="flex h-11 items-center gap-2.5 rounded-lg bg-ink px-4 font-mono text-[13px] text-paper"
        style="box-shadow: 0 0 0 1px rgba(234,88,12,0.22), 0 6px 20px -8px rgba(234,88,12,0.30);"
      >
        <span class="text-tang-600">$</span>
        <span data-install-cmd>npm i -g tangly</span>
        <button
          type="button"
          aria-label="Copy command"
          data-install-copy
          class="group ml-3 flex h-5 w-5 items-center justify-center rounded text-mute transition-colors hover:text-paper data-[copied=true]:text-tang-300"
        >
          <Copy size={11} class="group-data-[copied=true]:hidden" />
          <Check size={11} class="hidden group-data-[copied=true]:inline" />
        </button>
      </div>
      <a
        href="https://docs.tangly.dev"
        class="flex h-11 items-center rounded-lg border border-line-light bg-paper px-4 font-sans text-[13px] font-medium text-ink hover:border-ink/30"
      >
        Read the docs
      </a>
    </div>
  </div>
</section>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-install-copy]");
  const cmd = document.querySelector<HTMLElement>("[data-install-cmd]");
  if (btn && cmd) {
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(cmd.textContent?.trim() ?? "");
      } catch {
        return;
      }
      const prev = btn.getAttribute("aria-label");
      btn.setAttribute("aria-label", "Copied");
      btn.dataset.copied = "true";
      setTimeout(() => {
        btn.setAttribute("aria-label", prev ?? "Copy command");
        delete btn.dataset.copied;
      }, 1500);
    });
  }
</script>

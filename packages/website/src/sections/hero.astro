---
import { Copy, ArrowRight } from "lucide-astro";
---

<section
  class="relative flex flex-col gap-14 overflow-hidden bg-paper px-24 pb-12 pt-24"
>
  <!-- decorative tang glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-[260px] -right-[300px] h-[720px] w-[720px] rounded-full"
    style="background: radial-gradient(circle at center, rgba(234,88,12,0.10) 0%, rgba(234,88,12,0.03) 45%, rgba(234,88,12,0) 70%);"
  >
  </div>

  <!-- decorative grid -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-60"
    style="background-image: linear-gradient(to right, rgba(31,31,35,0.025) 1px, transparent 1px), linear-gradient(to bottom, rgba(31,31,35,0.025) 1px, transparent 1px); background-size: 48px 48px;"
  >
  </div>

  <!-- decorative Möbius mark -->
  <img
    aria-hidden="true"
    src="/brand/tangly-icon-1024.png"
    alt=""
    class="pointer-events-none absolute top-[100px] -right-[120px] h-[520px] w-[520px] rotate-[-8deg] opacity-10"
  />

  <div class="relative z-10 flex max-w-[1100px] flex-col gap-9">
    <h1 class="flex flex-col font-sans font-extrabold tracking-[-0.04em]">
      <span
        class="text-[132px] leading-[0.92] text-ink"
      >Open-source<br />documentation,</span>
      <span
        class="text-[132px] leading-[0.92]"
        style="background: linear-gradient(135deg, #F97316 0%, #C2410C 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; color: transparent;"
      >self-hosted.</span>
    </h1>
    <p class="max-w-[660px] font-sans text-[22px] leading-8 text-mute">
      Tangly turns a folder of Markdown into a fast, themed, deployable docs
      site. No proprietary backend, no monthly bill — just a static binary and
      your repo.
    </p>
  </div>

  <div class="relative z-10 flex items-center gap-3">
    <div
      class="flex h-[52px] items-center gap-3 rounded-[10px] bg-ink px-[22px] font-mono text-sm text-paper"
      style="box-shadow: 0 0 0 1px rgba(234,88,12,0.25), 0 8px 24px -8px rgba(234,88,12,0.35);"
    >
      <span class="text-tang-600">$</span>
      <span>curl tangly.dev/install.sh | sh</span>
      <button
        type="button"
        aria-label="Copy command"
        class="ml-4 flex h-6 w-6 items-center justify-center rounded-md bg-line-dark text-mute"
      >
        <Copy size={11} />
      </button>
    </div>
    <a
      href="https://github.com/tanglydocs/tangly"
      class="flex h-[52px] items-center gap-2 rounded-[10px] border border-line-light px-[22px] font-sans text-sm font-medium text-ink"
    >
      View README.md
      <ArrowRight size={14} />
    </a>
  </div>
</section>

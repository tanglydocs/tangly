---
import { ArrowUpRight } from "lucide-astro";

// Five themes. Switch by setting the `theme` field in docs.json. `starter` is
// not a theme: it's the default `tangly init` scaffold (it ships on `tang`).
const themes = [
  {
    name: "Tang",
    slug: "tang",
    badge: "default",
    blurb: "Mintlify-Mint inspired. Sidebar nav, on-page TOC, monospace headings.",
    use: '"theme": "tang"',
    shot: "/themes/tang.webp",
  },
  {
    name: "Pith",
    slug: "pith",
    badge: "editorial",
    blurb: "Serif headings, cream surface, generous measure. For long-form writing.",
    use: '"theme": "pith"',
    shot: "/themes/pith.webp",
  },
  {
    name: "Pip",
    slug: "pip",
    badge: "minimal",
    blurb: "No sidebar. Single-column reading mode. Headings as the only navigation.",
    use: '"theme": "pip"',
    shot: "/themes/pip.webp",
  },
  {
    name: "Readable",
    slug: "readable",
    badge: "book-like",
    blurb: "Narrow column, large body type, drop caps. Reads like a manual.",
    use: '"theme": "readable"',
    shot: "/themes/readable.webp",
  },
  {
    name: "Geist",
    slug: "geist",
    badge: "developer",
    blurb: "Vercel/Linear register. Ink ground, thin rules, dense type scale.",
    use: '"theme": "geist"',
    shot: "/themes/geist.webp",
  },
  {
    name: "Starter",
    slug: "starter",
    badge: "scaffold",
    blurb: "The default `tangly init` scaffold. Three sections, three pages, on the tang theme. The fastest way to start typing.",
    use: "tangly init",
    shot: "/themes/starter.webp",
  },
];
---

<section id="themes" class="border-t border-line-light bg-paper">
  <div class="mx-auto max-w-[1200px] px-10 pb-24 pt-20">
  <div class="flex items-end justify-between gap-8">
    <div class="flex max-w-[760px] flex-col gap-3">
      <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-tang-700">
        Themes
      </div>
      <h2
        class="flex flex-col font-sans text-[44px] font-extrabold leading-[1.05] tracking-[-0.025em]"
      >
        <span class="text-ink">Five themes.</span>
        <span class="text-tang-700">Same Markdown.</span>
      </h2>
      <p class="max-w-[520px] font-sans text-[15px] leading-6 text-mute">
        Swap a one-line value in <code class="font-mono text-[14px] text-ink"
          >docs.json</code
        >. Same content, new register. Each tile is a real Tangly site.
        Click through to <a
          href="https://examples.tangly.dev"
          class="text-ink underline decoration-line-light underline-offset-2 hover:decoration-tang-600">examples.tangly.dev</a
        >.
      </p>
    </div>
    <a
      href="https://examples.tangly.dev"
      class="flex items-center gap-1.5 font-sans text-[13px] font-medium text-ink"
      >Browse the gallery <span class="text-tang-600">→</span></a
    >
  </div>

  <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
    {
      themes.map((t) => (
        <a
          href={`https://examples.tangly.dev/${t.slug}/`}
          class="group flex flex-col overflow-hidden rounded-xl border border-line-light bg-paper transition-colors hover:border-tang-600"
        >
          <div class="aspect-[16/10] overflow-hidden border-b border-line-light bg-line-light/40">
            <img
              src={t.shot}
              alt={`${t.name} live demo`}
              width="1200"
              height="750"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.015]"
            />
          </div>
          <div class="flex flex-col gap-2 px-5 py-4">
            <div class="flex items-center justify-between gap-2">
              <div class="flex items-center gap-2">
                <div class="h-1.5 w-1.5 rounded-full bg-tang-600"></div>
                <div class="font-sans text-[13px] font-semibold text-ink">
                  {t.name}
                </div>
                <div class="rounded-full border border-line-light px-1.5 py-px font-mono text-[9px] uppercase tracking-[0.04em] text-mute">
                  {t.badge}
                </div>
              </div>
              <span class="flex items-center gap-1 font-sans text-[11px] font-medium text-ink">
                Open <ArrowUpRight size={11} color="#EA580C" />
              </span>
            </div>
            <p class="font-sans text-[12.5px] leading-[19px] text-mute">
              {t.blurb}
            </p>
            <div class="mt-1 font-mono text-[10.5px] text-mute">{t.use}</div>
          </div>
        </a>
      ))
    }
  </div>
  </div>
</section>

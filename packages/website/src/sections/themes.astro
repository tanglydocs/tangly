---
import { ArrowUpRight } from "lucide-astro";

const themes = [
  {
    name: "Tang",
    badge: "default",
    blurb: "Mintlify-Mint inspired. Sidebar nav, on-page TOC, monospace headings.",
    init: "tangly init --theme tang",
    tile: { bg: "#FAFAF7", textColor: "#0B0B0F", muteColor: "#1F1F23", font: '"Inter"', headlineWeight: 600, headlineSize: 28, bodyFont: '"Inter"', bodyWeight: 400 },
  },
  {
    name: "Pith",
    badge: "editorial",
    blurb: "Serif headings, cream surface, generous measure. For long-form writing.",
    init: "tangly init --theme pith",
    tile: { bg: "#F5EFDD", textColor: "#0B0B0F", muteColor: "#1F1F23", font: '"Source Serif 4", serif', headlineWeight: 600, headlineSize: 30, bodyFont: '"Source Serif 4", serif', bodyWeight: 400 },
  },
  {
    name: "Pip",
    badge: "minimal",
    blurb: "No sidebar. Single-column reading mode. Headings as the only navigation.",
    init: "tangly init --theme pip",
    tile: { bg: "#FAFAF7", textColor: "#0B0B0F", muteColor: "#1F1F23", font: '"Inter"', headlineWeight: 700, headlineSize: 26, bodyFont: '"Inter"', bodyWeight: 400 },
  },
  {
    name: "Readable",
    badge: "book-like",
    blurb: "Narrow column, large body type, drop caps. Reads like a manual.",
    init: "tangly init --theme readable",
    tile: { bg: "#FAFAF7", textColor: "#0B0B0F", muteColor: "#1F1F23", font: '"EB Garamond", serif', headlineWeight: 500, headlineSize: 32, bodyFont: '"EB Garamond", serif', bodyWeight: 400 },
  },
  {
    name: "Geist",
    badge: "developer",
    blurb: "Vercel/Linear register. Ink ground, thin rules, dense type scale.",
    init: "tangly init --theme geist",
    tile: { bg: "#0B0B0F", textColor: "#FAFAF7", muteColor: "#A0A0A8", font: '"Geist"', headlineWeight: 600, headlineSize: 28, bodyFont: '"Geist"', bodyWeight: 400, dark: true },
  },
  {
    name: "Starter",
    badge: "scaffold",
    blurb: "Three sections, three pages, no opinions. The fastest way to start typing.",
    init: "tangly init --theme starter",
    tile: { bg: "#FAFAF7", textColor: "#0B0B0F", muteColor: "#1F1F23", font: '"Inter"', headlineWeight: 500, headlineSize: 28, bodyFont: '"Inter"', bodyWeight: 400 },
  },
];
---

<section id="themes" class="border-t border-line-light bg-paper">
  <div class="mx-auto max-w-[1200px] px-10 pb-24 pt-20">
  <div class="flex items-end justify-between gap-8">
    <div class="flex max-w-[760px] flex-col gap-3">
      <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-tang-700">
        Themes
      </div>
      <h2
        class="flex flex-col font-sans text-[44px] font-extrabold leading-[1.05] tracking-[-0.025em]"
      >
        <span class="text-ink">Six themes.</span>
        <span class="text-tang-700">Same Markdown.</span>
      </h2>
      <p class="max-w-[520px] font-sans text-[15px] leading-6 text-mute">
        Swap a one-line value in <code class="font-mono text-[14px] text-ink"
          >docs.json</code
        >. Same content, new register.
      </p>
    </div>
    <a
      href="/themes"
      class="flex items-center gap-1.5 font-sans text-[13px] font-medium text-ink"
      >Browse the gallery <span class="text-tang-600">→</span></a
    >
  </div>

  <div class="mt-10 flex flex-wrap gap-4">
    {
      themes.map((t) => {
        const dark = t.tile.dark;
        return (
          <div
            class:list={[
              "flex flex-col overflow-hidden rounded-xl border",
              dark ? "border-line-dark" : "border-line-light",
            ]}
            style={`background: ${t.tile.bg}; width: calc((100% - 32px) / 3);`}
          >
            <div
              class:list={[
                "flex items-center justify-between border-b px-3.5 py-2.5",
                dark ? "border-line-dark" : "border-line-light",
              ]}
            >
              <div class="flex items-center gap-2">
                <div class="h-1.5 w-1.5 rounded-full bg-tang-600"></div>
                <div
                  class="font-sans text-[12px] font-semibold"
                  style={`color: ${t.tile.textColor};`}
                >
                  {t.name}
                </div>
                <div
                  class:list={[
                    "rounded-full border px-1.5 py-px font-mono text-[9px] uppercase tracking-[0.04em]",
                    dark ? "border-line-dark text-mute" : "border-line-light text-mute",
                  ]}
                >
                  {t.badge}
                </div>
              </div>
              <div class="font-mono text-[10px] text-mute">/theme</div>
            </div>
            <div
              class="flex min-h-[170px] flex-1 flex-col gap-2.5 px-5 py-6"
            >
              <div
                class="font-mono text-[10px] uppercase tracking-[0.04em] text-mute"
              >
                Get started
              </div>
              <div
                style={`font-family: ${t.tile.font}; font-weight: ${t.tile.headlineWeight}; font-size: ${t.tile.headlineSize - 6}px; line-height: ${t.tile.headlineSize}px; letter-spacing: -0.02em; color: ${t.tile.textColor};`}
              >
                Self-host your docs.
              </div>
              <div
                style={`font-family: ${t.tile.bodyFont}; font-weight: ${t.tile.bodyWeight}; font-size: 12.5px; line-height: 19px; color: ${t.tile.muteColor};`}
              >
                Tangly turns Markdown into a fast, themed, deployable site.
              </div>
            </div>
            <div
              class:list={[
                "flex items-center justify-between border-t px-3.5 py-2.5",
                dark ? "border-line-dark" : "border-line-light",
              ]}
            >
              <div class="font-mono text-[10px] text-mute">
                {t.init}
              </div>
              <a
                href="/themes"
                class="flex items-center gap-1 font-sans text-[11px] font-medium"
                style={`color: ${t.tile.textColor};`}
              >
                Preview <ArrowUpRight size={11} color="#EA580C" />
              </a>
            </div>
          </div>
        );
      })
    }
  </div>
  </div>
</section>

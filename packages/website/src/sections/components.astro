---
import Note from "@tanglydocs/theme-ui/components/Note.astro";
import Tip from "@tanglydocs/theme-ui/components/Tip.astro";
import Warning from "@tanglydocs/theme-ui/components/Warning.astro";
import Danger from "@tanglydocs/theme-ui/components/Danger.astro";
import Info from "@tanglydocs/theme-ui/components/Info.astro";
import Check from "@tanglydocs/theme-ui/components/Check.astro";
import Update from "@tanglydocs/theme-ui/components/Update.astro";
import Card from "@tanglydocs/theme-ui/components/Card.astro";
import CardGroup from "@tanglydocs/theme-ui/components/CardGroup.astro";
import Columns from "@tanglydocs/theme-ui/components/Columns.astro";
import Frame from "@tanglydocs/theme-ui/components/Frame.astro";
import Tabs from "@tanglydocs/theme-ui/components/Tabs.astro";
import Tab from "@tanglydocs/theme-ui/components/Tab.astro";
import Steps from "@tanglydocs/theme-ui/components/Steps.astro";
import Step from "@tanglydocs/theme-ui/components/Step.astro";
import Accordion from "@tanglydocs/theme-ui/components/Accordion.astro";
import AccordionGroup from "@tanglydocs/theme-ui/components/AccordionGroup.astro";
import CodeGroup from "@tanglydocs/theme-ui/components/CodeGroup.astro";
import FileTree from "@tanglydocs/theme-ui/components/FileTree.astro";
import Snippet from "@tanglydocs/theme-ui/components/Snippet.astro";
import LightboxImage from "@tanglydocs/theme-ui/components/LightboxImage.astro";
// Embed needs Tangly's manifest virtual module, render a static placeholder.
import ParamField from "@tanglydocs/theme-ui/components/ParamField.astro";
import ResponseField from "@tanglydocs/theme-ui/components/ResponseField.astro";
import RequestExample from "@tanglydocs/theme-ui/components/RequestExample.astro";
import ResponseExample from "@tanglydocs/theme-ui/components/ResponseExample.astro";
import Badge from "@tanglydocs/theme-ui/components/Badge.astro";
import Icon from "@tanglydocs/theme-ui/components/Icon.astro";
import Kbd from "@tanglydocs/theme-ui/components/Kbd.astro";
import Tooltip from "@tanglydocs/theme-ui/components/Tooltip.astro";
import GlossaryTerm from "@tanglydocs/theme-ui/components/GlossaryTerm.astro";
import Expandable from "@tanglydocs/theme-ui/components/Expandable.astro";
import PackageManager from "@tanglydocs/theme-ui/components/PackageManager.astro";
import { Code } from "astro:components";

// Real Shiki render for the rendering block (not a screenshot).
const codeSample = `export async function search(q: string) {
  const index = await load("/pagefind");
  return index.search(q);
}`;

const groups: Array<{ label: string; count: number; tiles: string[] }> = [
  { label: "Callouts", count: 7, tiles: ["Note", "Tip", "Warning", "Danger", "Info", "Check", "Update"] },
  { label: "Layout", count: 4, tiles: ["Card", "CardGroup", "Columns", "Frame"] },
  { label: "Navigation", count: 6, tiles: ["Tabs", "Tab", "Steps", "Step", "Accordion", "AccordionGroup"] },
  { label: "Code & content", count: 6, tiles: ["CodeGroup", "FileTree", "Snippet", "Embed", "Video", "LightboxImage"] },
  { label: "API", count: 4, tiles: ["ParamField", "ResponseField", "RequestExample", "ResponseExample"] },
  { label: "OpenAPI", count: 4, tiles: ["OpenApiEndpoint", "OpenApiRedoc", "OpenApiScalar", "OpenApiStoplight"] },
  { label: "Inline & misc", count: 7, tiles: ["Badge", "Icon", "Kbd", "Tooltip", "GlossaryTerm", "Expandable", "PackageManager"] },
];
---

<section id="components" class="border-t border-line-light bg-paper">
  <div class="mx-auto max-w-[1200px] px-10 pb-24 pt-20">
  <div class="flex max-w-[760px] flex-col gap-3">
    <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-tang-700">
      Components
    </div>
    <h2
      class="flex flex-col font-sans text-[44px] font-extrabold leading-[1.05] tracking-[-0.025em]"
    >
      <span class="text-ink">38 components,</span>
      <span class="text-tang-700">no imports.</span>
    </h2>
    <p class="max-w-[560px] font-sans text-[15px] leading-6 text-mute">
      Drop a tag in MDX. Every theme ships every component. Render here uses
      the real <code class="font-mono text-[14px] text-ink">@tanglydocs/theme-ui</code> package, not screenshots.
    </p>
  </div>

  <div class="ws-components mt-10 overflow-hidden rounded-xl border border-line-light bg-paper">
    {
      groups.map((g, gi) => (
        <div
          class:list={[
            "flex flex-col gap-4 px-8 pb-8 pt-7",
            gi < groups.length - 1 ? "border-b border-line-light" : "",
          ]}
        >
          <div class="flex items-center gap-3">
            <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-mute">
              {g.label}
            </div>
            <div class="h-px flex-1 bg-line-light"></div>
            <div class="font-mono text-[11px] text-mute">{g.count}</div>
          </div>
          <div class="flex flex-wrap gap-4">
            {g.tiles.map((tag) => (
              <div class="ws-tile flex flex-col gap-2" style="width: calc((100% - 32px) / 3);">
                <div class="font-mono text-[10px] uppercase tracking-[0.06em] text-mute">
                  &lt;{tag}&gt;
                </div>
                <div class="ws-render">
                  {tag === "Note" && <Note>Heads up, worth a read.</Note>}
                  {tag === "Tip" && <Tip>Quick win. Try this.</Tip>}
                  {tag === "Warning" && <Warning>Mind the gap.</Warning>}
                  {tag === "Danger" && <Danger>Don't ship this.</Danger>}
                  {tag === "Info" && <Info>Some context.</Info>}
                  {tag === "Check" && <Check>Done. Confirmed.</Check>}
                  {tag === "Update" && (
                    <Update label="v0.1.0" description="May 2026" tags={["feat"]}>
                      Open-source release.
                    </Update>
                  )}
                  {tag === "Card" && (
                    <Card title="Quickstart" icon="terminal" href="https://docs.tangly.dev/quickstart">
                      Three commands.
                    </Card>
                  )}
                  {tag === "CardGroup" && (
                    <CardGroup cols={2}>
                      <Card title="Get started" icon="rocket" href="https://docs.tangly.dev/quickstart" />
                      <Card title="Themes" icon="paintbrush" href="https://docs.tangly.dev/guides/themes/" />
                    </CardGroup>
                  )}
                  {tag === "Columns" && (
                    <Columns cols={3}>
                      <div class="rounded bg-line-light/60 p-2 text-center font-mono text-[11px] text-mute">A</div>
                      <div class="rounded bg-line-light/60 p-2 text-center font-mono text-[11px] text-mute">B</div>
                      <div class="rounded bg-line-light/60 p-2 text-center font-mono text-[11px] text-mute">C</div>
                    </Columns>
                  )}
                  {tag === "Frame" && (
                    <Frame caption="Hero illustration">
                      <div class="aspect-video w-full bg-gradient-to-br from-tang-300 to-tang-700"></div>
                    </Frame>
                  )}
                  {tag === "Tabs" && (
                    <Tabs name="install-demo">
                      <Tab title="npm"><pre class="!my-0 font-mono text-xs">npm i -g tangly</pre></Tab>
                      <Tab title="bun"><pre class="!my-0 font-mono text-xs">bun add -g tangly</pre></Tab>
                      <Tab title="curl"><pre class="!my-0 font-mono text-xs">curl tangly.dev/install.sh | sh</pre></Tab>
                    </Tabs>
                  )}
                  {tag === "Tab" && (
                    <p class="py-2 font-sans text-[12px] leading-[18px] text-mute">
                      Child of <code class="font-mono text-ink">&lt;Tabs&gt;</code>. One panel.
                    </p>
                  )}
                  {tag === "Steps" && (
                    <Steps>
                      <Step title="Install">npm i -g tangly</Step>
                      <Step title="Init">tangly init</Step>
                      <Step title="Build">tangly build</Step>
                    </Steps>
                  )}
                  {tag === "Step" && (
                    <p class="py-2 font-sans text-[12px] leading-[18px] text-mute">
                      Child of <code class="font-mono text-ink">&lt;Steps&gt;</code>. One step.
                    </p>
                  )}
                  {tag === "Accordion" && (
                    <Accordion title="Why Tangly?" defaultOpen>
                      Self-host. No vendor lock-in.
                    </Accordion>
                  )}
                  {tag === "AccordionGroup" && (
                    <AccordionGroup>
                      <Accordion title="Free?">Apache-2.0.</Accordion>
                      <Accordion title="Mintlify compat?">Drop-in.</Accordion>
                    </AccordionGroup>
                  )}
                  {tag === "CodeGroup" && (
                    <CodeGroup>
                      <pre data-tab-title="bun" class="language-bash"><code>bun add tangly</code></pre>
                      <pre data-tab-title="npm" class="language-bash"><code>npm i tangly</code></pre>
                      <pre data-tab-title="pnpm" class="language-bash"><code>pnpm add tangly</code></pre>
                    </CodeGroup>
                  )}
                  {tag === "FileTree" && (
                    <FileTree>
                      <ul>
                        <li>my-docs<ul>
                          <li>docs.json</li>
                          <li>intro.mdx</li>
                          <li>api/<ul><li>openapi.yaml</li></ul></li>
                        </ul></li>
                      </ul>
                    </FileTree>
                  )}
                  {tag === "Snippet" && (
                    <Snippet file="install.snippet.mdx">
                      <pre class="!my-0 rounded-md bg-ink p-3 font-mono text-xs text-paper">$ tangly init my-docs</pre>
                    </Snippet>
                  )}
                  {tag === "Embed" && (
                    <div class="rounded-lg border border-line-light p-3.5 bg-paper">
                      <div class="font-mono text-[10px] text-mute mb-1.5">codepen.io / · 240×80</div>
                      <div class="flex gap-1"><span class="h-1.5 w-1.5 rounded-full bg-line-light"></span><span class="h-1.5 w-1.5 rounded-full bg-line-light"></span><span class="h-1.5 w-1.5 rounded-full bg-line-light"></span></div>
                    </div>
                  )}
                  {tag === "Video" && (
                    <div class="relative aspect-video w-full overflow-hidden rounded-lg bg-ink">
                      <div class="absolute inset-0 flex items-center justify-center">
                        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-paper/90">
                          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 translate-x-px fill-ink"><path d="M8 5v14l11-7z" /></svg>
                        </span>
                      </div>
                      <span class="absolute bottom-1.5 left-2 font-mono text-[10px] text-paper/70">demo.mp4</span>
                    </div>
                  )}
                  {tag === "LightboxImage" && (
                    <LightboxImage src="/brand/tangly-icon-512.png" alt="Tangly Möbius mark" width={120} height={120} />
                  )}
                  {tag === "ParamField" && (
                    <ParamField path="q" type="string" required>
                      Search query.
                    </ParamField>
                  )}
                  {tag === "ResponseField" && (
                    <ResponseField name="id" type="uuid">
                      Domain ID.
                    </ResponseField>
                  )}
                  {tag === "RequestExample" && (
                    <RequestExample>
                      <pre class="!my-0 language-bash"><code>curl api.tangly.dev/v1
  -H "Auth: $TOKEN"</code></pre>
                    </RequestExample>
                  )}
                  {tag === "ResponseExample" && (
                    <ResponseExample>
                      <pre class="!my-0 language-json"><code>{`{ "id": "d_47" }`}</code></pre>
                    </ResponseExample>
                  )}
                  {tag === "OpenApiEndpoint" && (
                    <div class="flex flex-col gap-1.5 rounded-lg border border-line-light bg-paper p-3">
                      <div class="flex items-center gap-2">
                        <span class="rounded bg-ink/[0.06] px-1.5 py-px font-mono text-[10px] font-semibold text-ink">GET</span>
                        <span class="font-mono text-[11px] text-ink">/v1/domains</span>
                      </div>
                      <div class="font-sans text-[11px] leading-4 text-mute">Endpoint page, generated from your spec.</div>
                      <div class="w-fit rounded border border-tang-600/40 px-2 py-px font-mono text-[10px] text-tang-700">Try it</div>
                    </div>
                  )}
                  {tag === "OpenApiRedoc" && (
                    <div class="flex flex-col gap-1.5 rounded-lg border border-line-light bg-paper p-3">
                      <div class="flex items-center justify-between">
                        <span class="rounded bg-ink/[0.06] px-1.5 py-px font-mono text-[10px] font-semibold text-ink">POST</span>
                        <span class="font-mono text-[9px] uppercase tracking-[0.08em] text-mute">Redoc</span>
                      </div>
                      <span class="font-mono text-[11px] text-ink">/v1/orders</span>
                      <div class="flex flex-col gap-1 pt-0.5">
                        <div class="h-1 w-full rounded-full bg-line-light"></div>
                        <div class="h-1 w-2/3 rounded-full bg-line-light"></div>
                      </div>
                    </div>
                  )}
                  {tag === "OpenApiScalar" && (
                    <div class="flex flex-col gap-1.5 rounded-lg border border-line-light bg-paper p-3">
                      <div class="flex items-center justify-between">
                        <span class="rounded bg-ink/[0.06] px-1.5 py-px font-mono text-[10px] font-semibold text-ink">GET</span>
                        <span class="font-mono text-[9px] uppercase tracking-[0.08em] text-mute">Scalar</span>
                      </div>
                      <span class="font-mono text-[11px] text-ink">/v1/usage</span>
                      <div class="flex flex-col gap-1 pt-0.5">
                        <div class="h-1 w-full rounded-full bg-line-light"></div>
                        <div class="h-1 w-1/2 rounded-full bg-line-light"></div>
                      </div>
                    </div>
                  )}
                  {tag === "OpenApiStoplight" && (
                    <div class="flex flex-col gap-1.5 rounded-lg border border-line-light bg-paper p-3">
                      <div class="flex items-center justify-between">
                        <span class="rounded bg-ink/[0.06] px-1.5 py-px font-mono text-[10px] font-semibold text-ink">DELETE</span>
                        <span class="font-mono text-[9px] uppercase tracking-[0.08em] text-mute">Stoplight</span>
                      </div>
                      <span class="font-mono text-[11px] text-ink">/v1/keys/{`{id}`}</span>
                      <div class="flex flex-col gap-1 pt-0.5">
                        <div class="h-1 w-full rounded-full bg-line-light"></div>
                        <div class="h-1 w-3/4 rounded-full bg-line-light"></div>
                      </div>
                    </div>
                  )}
                  {tag === "Badge" && (
                    <p class="!my-0 flex flex-wrap items-center gap-2">
                      <Badge variant="accent">v0.1</Badge>
                      <Badge variant="success">new</Badge>
                      <Badge variant="warning">beta</Badge>
                    </p>
                  )}
                  {tag === "Icon" && (
                    <p class="!my-0 flex items-center gap-3 text-ink">
                      <Icon icon="terminal" size={18} />
                      <Icon icon="rocket" size={18} />
                      <Icon icon="search" size={18} />
                      <Icon icon="folder" size={18} />
                    </p>
                  )}
                  {tag === "Kbd" && (
                    <p class="!my-0 font-sans text-sm text-line-dark">
                      Press <Kbd keys="Cmd+K" />
                    </p>
                  )}
                  {tag === "Tooltip" && (
                    <p class="!my-0 font-sans text-sm text-line-dark">
                      <Tooltip tip="Server-sent events">SSE stream</Tooltip>
                    </p>
                  )}
                  {tag === "GlossaryTerm" && (
                    <p class="!my-0 font-sans text-sm leading-5 text-line-dark">
                      An <GlossaryTerm slug="mdx" definition="Markdown plus JSX" href="https://docs.tangly.dev/reference/markdown/#mdx">MDX</GlossaryTerm> file is markdown plus JSX.
                    </p>
                  )}
                  {tag === "Expandable" && (
                    <Expandable title="advanced opts">
                      Three optional fields.
                    </Expandable>
                  )}
                  {tag === "PackageManager" && (
                    <PackageManager name="tangly" syncName="ws-pm-demo" />
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <div class="ws-render-block mt-10 rounded-xl border border-line-light bg-paper p-8">
    <div class="flex items-center gap-3">
      <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-tang-700">Rendering</div>
      <div class="h-px flex-1 bg-line-light"></div>
      <div class="font-mono text-[11px] text-mute">code · math · diagrams</div>
    </div>
    <p class="mt-3 max-w-[600px] font-sans text-[15px] leading-6 text-mute">
      Not components. Markdown syntax, wired by default. Shiki highlighting with line
      highlights, diffs, and titles. KaTeX math. Mermaid diagrams. Every page, every theme.
    </p>

    <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-3">
      <div class="flex flex-col gap-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.06em] text-mute">Code · Shiki</div>
        <div class="overflow-hidden rounded-lg border border-line-light">
          <div class="flex items-center gap-1.5 border-b border-line-light bg-paper px-3 py-1.5">
            <span class="h-2 w-2 rounded-full bg-line-light"></span>
            <span class="font-mono text-[10px] text-mute">search.ts</span>
          </div>
          <Code code={codeSample} lang="ts" theme="github-light" />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.06em] text-mute">Diagrams · Mermaid</div>
        <div class="flex flex-1 items-center justify-center rounded-lg border border-line-light bg-paper p-4">
          <svg viewBox="0 0 220 140" class="w-full max-w-[220px]" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mermaid flow: docs.json to tangly build to dist and llms.txt">
            <defs>
              <marker id="ws-arrow" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto">
                <path d="M0 0 L6 3 L0 6 Z" fill="#EA580C" />
              </marker>
            </defs>
            <rect x="68" y="6" width="84" height="26" rx="6" fill="#FAFAF7" stroke="#E6E4DE" />
            <text x="110" y="23" text-anchor="middle" font-family="monospace" font-size="11" fill="#0B0B0F">docs.json</text>
            <path d="M110 32 L110 52" stroke="#EA580C" stroke-width="1.5" marker-end="url(#ws-arrow)" />
            <rect x="60" y="54" width="100" height="26" rx="6" fill="#FAFAF7" stroke="#E6E4DE" />
            <text x="110" y="71" text-anchor="middle" font-family="monospace" font-size="11" fill="#0B0B0F">tangly build</text>
            <path d="M90 80 L54 104" stroke="#EA580C" stroke-width="1.5" marker-end="url(#ws-arrow)" />
            <path d="M130 80 L166 104" stroke="#EA580C" stroke-width="1.5" marker-end="url(#ws-arrow)" />
            <rect x="14" y="106" width="64" height="26" rx="6" fill="#FAFAF7" stroke="#E6E4DE" />
            <text x="46" y="123" text-anchor="middle" font-family="monospace" font-size="11" fill="#0B0B0F">dist/</text>
            <rect x="140" y="106" width="72" height="26" rx="6" fill="#FAFAF7" stroke="#E6E4DE" />
            <text x="176" y="123" text-anchor="middle" font-family="monospace" font-size="10" fill="#0B0B0F">llms.txt</text>
          </svg>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.06em] text-mute">Math · KaTeX</div>
        <div
          class="flex flex-1 items-center justify-center rounded-lg border border-line-light bg-paper p-4 text-ink"
          style="font-family: 'Source Serif 4', Georgia, serif;"
        >
          <span class="relative mr-2 text-[34px] leading-none">∑
            <span class="absolute -top-0.5 left-0 text-[10px] not-italic">∞</span>
            <span class="absolute -bottom-2 left-0 text-[10px] italic">n=1</span>
          </span>
          <div class="flex flex-col items-center text-[16px] italic">
            <span>1</span>
            <span class="my-0.5 h-px w-full bg-ink"></span>
            <span>n²</span>
          </div>
          <span class="mx-2 text-[18px]">=</span>
          <div class="flex flex-col items-center text-[16px] italic">
            <span>π²</span>
            <span class="my-0.5 h-px w-full bg-ink"></span>
            <span>6</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>

<style>
  /* Tame theme-ui's vertical rhythm so each component sits inside its tile. */
  .ws-components :global(.ws-render > *) {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
  .ws-components :global(.ws-render) {
    font-size: 13px;
  }
  .ws-components :global(.tangly-callout) {
    padding: 0.6rem 0.75rem;
  }
  .ws-components :global(.tangly-tabs) {
    margin: 0;
  }
  .ws-components :global(.tangly-steps) {
    margin: 0;
  }
  .ws-components :global(.tangly-update) {
    margin: 0;
    padding: 0.75rem 0.875rem;
  }
  /* Compact the real Shiki <Code> render inside the rendering block. */
  .ws-render-block :global(.astro-code) {
    margin: 0;
    padding: 0.7rem 0.85rem;
    font-size: 12px;
    line-height: 1.55;
    border-radius: 0;
    overflow-x: auto;
  }
</style>

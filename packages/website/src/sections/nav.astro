---
import { Github } from "lucide-astro";
---

<nav class="flex items-center justify-between px-24 py-8">
  <div class="flex items-center gap-2">
    <img
      src="/brand/tangly-icon-256.png"
      alt=""
      width="22"
      height="22"
      class="h-[22px] w-[22px]"
    />
    <span class="font-sans text-[18px] font-bold tracking-[-0.015em] text-ink"
      >Tangly</span
    >
  </div>
  <a
    href="https://github.com/tanglydocs/tangly"
    aria-label="GitHub"
    class="flex h-8 w-8 items-center justify-center text-ink"
  >
    <Github size={20} />
  </a>
</nav>

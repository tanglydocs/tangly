---
const providers = [
  {
    name: "Vercel",
    cmd: "vercel deploy ./dist",
    href: "https://vercel.com",
    logo: "/brand/logos/vercel.svg",
    width: 26,
  },
  {
    name: "Cloudflare Pages",
    cmd: "wrangler pages deploy ./dist",
    href: "https://pages.cloudflare.com",
    logo: "/brand/logos/cloudflare.svg",
    width: 44,
  },
  {
    name: "Netlify",
    cmd: "netlify deploy --prod --dir dist",
    href: "https://netlify.com",
    logo: "/brand/logos/netlify.svg",
    width: 26,
  },
  {
    name: "GitHub Pages",
    cmd: "actions/deploy-pages@v4",
    href: "https://pages.github.com",
    logo: "/brand/logos/github.svg",
    width: 26,
  },
];
---

<section class="border-t border-line-light bg-paper">
  <div class="mx-auto max-w-[1200px] px-10 pb-24 pt-20">
  <div class="flex items-end justify-between gap-8">
    <div class="flex max-w-[760px] flex-col gap-3">
      <div class="font-mono text-[11px] uppercase tracking-[0.06em] text-tang-700">
        Deploy
      </div>
      <h2
        class="flex flex-col font-sans text-[44px] font-extrabold leading-[1.05] tracking-[-0.025em]"
      >
        <span class="text-ink">Static output.</span>
        <span class="text-tang-700">Ship anywhere.</span>
      </h2>
      <p class="max-w-[560px] font-sans text-[15px] leading-6 text-mute">
        <code class="font-mono text-[14px] text-ink">tangly build</code> emits a
        folder. Drop it on any host that serves files. No runtime, no Node
        process.
      </p>
    </div>
    <a
      href="https://docs.tangly.dev/guides/deploying"
      class="flex items-center gap-1.5 font-sans text-[13px] font-medium text-ink"
      >Read the deploy guide <span class="text-tang-600">→</span></a
    >
  </div>

  <div class="mt-10 flex flex-wrap items-center rounded-xl border border-line-light overflow-hidden">
    {
      providers.map((p, i) => (
        <a
          href={p.href}
          class:list={[
            "flex flex-1 flex-col items-start gap-3 px-6 py-5 hover:bg-line-light/30",
            i < providers.length - 1 ? "border-r border-line-light" : "",
          ]}
          style="min-width: 200px;"
        >
          <div class="flex h-6 items-center">
            <img src={p.logo} alt={`Deploy on ${p.name}`} width={p.width} height="24" style={`height: 24px; width: auto; max-width: ${p.width + 18}px;`} loading="lazy" decoding="async" />
          </div>
          <div class="flex flex-col gap-0.5">
            <div class="font-sans text-[14px] font-semibold text-ink">
              {p.name}
            </div>
            <div class="font-mono text-[11px] text-mute">{p.cmd}</div>
          </div>
        </a>
      ))
    }
  </div>
  </div>
</section>

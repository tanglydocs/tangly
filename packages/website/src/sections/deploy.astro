---
import { ArrowUpRight } from "lucide-astro";

const providers = [
  {
    name: "Vercel",
    cmd: "vercel deploy ./dist",
    href: "https://vercel.com",
    svg: `<svg width="28" height="24" viewBox="0 0 76 65" fill="#0B0B0F"><path d="M37.5274 0L75.0548 65H0L37.5274 0Z"/></svg>`,
  },
  {
    name: "Cloudflare Pages",
    cmd: "wrangler pages deploy ./dist",
    href: "https://pages.cloudflare.com",
    svg: `<svg width="32" height="24" viewBox="0 0 256 96" fill="#F38020"><path d="M202.957 41.226L184.722 30.802 181.62 29.514 102.262 30 101.66 39.93 148.296 42.756 73.55 44.13 70.444 53.706 145.236 54.94 113.184 56.32 110.078 65.45 192.93 65.45 198.63 49.51 202.957 41.226Z"/><path d="M213.336 19.85C211.07 19.85 208.872 20.066 206.748 20.474C202.79 7.84 191.064-1.45 177.16-1.45C160.62-1.45 147.014 11.184 145.388 27.53L142.92 26.85L96.4 27.144C75.024 27.444 56.748 41.45 50.498 60.65L49.498 64.65L74.024 65.6L213.336 65.45L213.336 19.85Z" opacity=".5"/></svg>`,
  },
  {
    name: "Netlify",
    cmd: "netlify deploy --prod --dir dist",
    href: "https://netlify.com",
    svg: `<svg width="28" height="28" viewBox="0 0 256 256" fill="#00AD9F"><path d="M52.69 152.57h0.69l37.65-15.66.21-1.31-13.57-13.49-1.4-.06-23.58 9.83v20.69ZM41 117.62l40.83-1.86 1.27.36 11.79 11.7 1.83 0 16.86-16.91L114 110l-13.46-13.7-21.84-2.04-37.7 23.36ZM163.66 116.95l30.34 11.91 13-30.42-30.34-11.92-13 30.43Z"/></svg>`,
  },
  {
    name: "GitHub Pages",
    cmd: "gh workflow run pages.yml",
    href: "https://pages.github.com",
    svg: `<svg width="28" height="28" viewBox="0 0 24 24" fill="#0B0B0F"><path d="M12 0a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.21.08 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.94 0-1.31.47-2.38 1.24-3.22-.13-.31-.54-1.53.12-3.18 0 0 1.01-.32 3.31 1.23a11.5 11.5 0 0 1 6.03 0c2.3-1.55 3.31-1.23 3.31-1.23.66 1.65.25 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 0z"/></svg>`,
  },
];
---

<section class="border-t border-line-light px-24 pb-30 pt-24">
  <div class="flex max-w-[880px] flex-col gap-4">
    <h2
      class="flex flex-col font-sans text-[64px] font-extrabold leading-none tracking-[-0.035em]"
    >
      <span class="text-ink">Static output.</span>
      <span class="text-tang-700">Ship anywhere.</span>
    </h2>
    <p class="max-w-[640px] font-sans text-lg leading-7 text-mute">
      <code class="font-mono text-base text-ink">tangly build</code> emits a
      folder. Drop it on any host that serves files. No runtime, no Node
      process.
    </p>
  </div>

  <div class="mt-14 flex flex-wrap items-center">
    {
      providers.map((p, i) => (
        <a
          href={p.href}
          class:list={[
            "flex flex-1 flex-col items-start gap-4 border border-line-light px-8 py-7",
            i < providers.length - 1 ? "border-r-0" : "",
          ]}
          style="min-width: 220px;"
        >
          <Fragment set:html={p.svg} />
          <div class="flex flex-col gap-1">
            <div class="font-sans text-base font-semibold text-ink">
              {p.name}
            </div>
            <div class="font-mono text-xs text-mute">{p.cmd}</div>
          </div>
        </a>
      ))
    }
  </div>
</section>

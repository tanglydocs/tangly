---
import { File } from "lucide-astro";
---

<section class="relative border-t border-line-light bg-paper">
  <!-- decorative tang glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-[55%] -translate-x-1/2 -translate-y-1/2"
    style="width: 70%; height: 55%; background: radial-gradient(ellipse at center, rgba(234,88,12,0.10) 0%, rgba(234,88,12,0.03) 40%, rgba(234,88,12,0) 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-[1200px] px-10 pb-24 pt-20">
    <div
      class="overflow-hidden rounded-xl border border-line-light bg-paper"
      style="box-shadow: 0 24px 48px -20px rgba(234,88,12,0.16), 0 1px 0 rgba(11,11,15,0.04);"
    >
      <!-- tab bar -->
      <div
        class="flex items-stretch border-b border-line-light"
        style="background: #F2EFE9;"
      >
        <div
          class="flex items-center gap-2 border-r border-line-light bg-paper px-4 py-3 font-mono text-[12px] text-ink"
        >
          <File size={12} class="text-mute" />
          introduction.mdx
        </div>
        <div class="flex-1"></div>
        <div
          class="flex items-center gap-2 px-4 py-3 font-mono text-[11px] text-mute"
        >
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-tang-600"></span>
          rendered with <code class="font-mono text-ink">tangly dev</code>
        </div>
      </div>

      <div class="flex">
        <!-- MDX source -->
        <div
          class="flex flex-1 flex-col bg-ink p-6 font-mono text-[12.5px] leading-[20px] text-line-light"
        >
          <div><span class="text-mute">---</span></div>
          <div><span class="text-tang-700">title:</span> <span class="text-tang-300">"Introduction"</span></div>
          <div><span class="text-tang-700">description:</span> <span class="text-tang-300">"What Tangly is"</span></div>
          <div><span class="text-mute">---</span></div>
          <div class="h-3"></div>
          <div>Tangly turns Markdown into a fast,</div>
          <div>themed, deployable docs site.</div>
          <div class="h-3"></div>
          <div><span class="text-tang-300">&lt;Note&gt;</span></div>
          <div>  Already have Mintlify? <span class="text-tang-300">`tangly dev`</span></div>
          <div>  renders your project as-is.</div>
          <div><span class="text-tang-300">&lt;/Note&gt;</span></div>
          <div class="h-3"></div>
          <div><span class="text-mute">## </span>Components</div>
          <div class="h-1"></div>
          <div><span class="text-tang-300">&lt;Card</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Install"</span></div>
          <div>  <span class="text-tang-700">icon</span>=<span class="text-tang-300">"terminal"</span><span class="text-tang-300">&gt;</span></div>
          <div>  One-line install via curl.</div>
          <div><span class="text-tang-300">&lt;/Card&gt;</span></div>
          <div class="h-3"></div>
          <div><span class="text-tang-300">&lt;Steps&gt;</span></div>
          <div>  <span class="text-tang-300">&lt;Step</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Install"</span><span class="text-tang-300">&gt;</span>...<span class="text-tang-300">&lt;/Step&gt;</span></div>
          <div>  <span class="text-tang-300">&lt;Step</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Init"</span><span class="text-tang-300">&gt;</span>...<span class="text-tang-300">&lt;/Step&gt;</span></div>
          <div>  <span class="text-tang-300">&lt;Step</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Build"</span><span class="text-tang-300">&gt;</span>...<span class="text-tang-300">&lt;/Step&gt;</span></div>
          <div><span class="text-tang-300">&lt;/Steps&gt;</span></div>
          <div class="h-3"></div>
          <div>Status: <span class="text-tang-300">&lt;Badge&gt;</span>stable<span class="text-tang-300">&lt;/Badge&gt;</span></div>
        </div>

        <!-- Rendered -->
        <div class="flex flex-1 flex-col bg-paper px-10 py-9">
          <div
            class="mb-2 flex items-center gap-1.5 font-sans text-[12px] text-mute"
          >
            <span>Documentation</span>
            <span class="text-line-light">›</span>
            <span>Introduction</span>
          </div>
          <div
            role="heading"
            aria-level="2"
            class="font-sans text-[32px] font-semibold leading-[38px] tracking-[-0.02em] text-ink"
          >
            Introduction
          </div>
          <p class="mt-1.5 font-sans text-[15px] leading-[22px] text-mute">
            What Tangly is
          </p>
          <p class="mt-5 font-sans text-[14px] leading-[22px] text-line-dark">
            Tangly turns Markdown into a fast, themed, deployable docs site.
          </p>

          <!-- Note callout -->
          <div
            class="mt-5 flex items-start gap-2.5 rounded-lg p-3"
            style="background: rgba(234,88,12,0.05); border: 1px solid rgba(234,88,12,0.18);"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#C2410C"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="mt-0.5 shrink-0"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            <p class="font-sans text-[12.5px] leading-5 text-line-dark">
              Already have Mintlify? <code
                class="rounded bg-ink/[0.06] px-1 py-px font-mono text-[11.5px] text-ink"
                >tangly dev</code
              > renders your project as-is.
            </p>
          </div>

          <div
            role="heading"
            aria-level="3"
            class="mt-7 font-sans text-[18px] font-semibold leading-6 tracking-[-0.015em] text-ink"
          >
            Components
          </div>

          <!-- Card -->
          <div
            class="mt-3 flex flex-col gap-1 rounded-lg border border-line-light bg-paper p-3.5"
          >
            <div class="flex items-center gap-2">
              <div
                class="flex h-7 w-7 items-center justify-center rounded-md"
                style="background: rgba(234,88,12,0.08);"
              >
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#C2410C"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="4 17 10 11 4 5"></polyline>
                  <line x1="12" y1="19" x2="20" y2="19"></line>
                </svg>
              </div>
              <span class="font-sans text-[13px] font-semibold text-ink"
                >Install</span
              >
              <div class="flex-1"></div>
              <span class="font-sans text-[13px] text-mute">→</span>
            </div>
            <p class="pl-9 font-sans text-[12px] leading-[18px] text-mute">
              One-line install via curl.
            </p>
          </div>

          <!-- Steps -->
          <div
            class="mt-3 flex flex-col gap-2.5 rounded-lg border border-line-light bg-paper p-3.5"
          >
            {[
              { n: 1, t: "Install", c: "npm i -g tangly", active: true },
              { n: 2, t: "Init", c: "tangly init", active: false },
              { n: 3, t: "Build", c: "tangly build", active: false },
            ].map((s) => (
              <div class="flex gap-2.5">
                <div
                  class:list={[
                    "flex h-[18px] w-[18px] shrink-0 items-center justify-center rounded-full font-sans text-[10px] font-semibold",
                    s.active
                      ? "bg-tang-600 text-paper"
                      : "border border-line-light text-mute",
                  ]}
                >
                  {s.n}
                </div>
                <div class="flex flex-col gap-px">
                  <div class="font-sans text-[12px] font-semibold text-ink">
                    {s.t}
                  </div>
                  <code class="font-mono text-[11px] text-mute">{s.c}</code>
                </div>
              </div>
            ))}
          </div>

          <!-- Badge inline -->
          <div class="mt-4 flex items-center gap-1.5">
            <span class="font-sans text-[12.5px] text-line-dark">Status:</span>
            <span
              class="inline-flex items-center rounded-full px-2 py-px font-mono text-[10px] font-semibold uppercase tracking-[0.04em] text-tang-700"
              style="background: rgba(234,88,12,0.08); border: 1px solid rgba(234,88,12,0.20);"
            >
              stable
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

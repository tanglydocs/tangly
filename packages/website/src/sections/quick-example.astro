---
import { File } from "lucide-astro";
---

<section class="relative px-24 pb-30 pt-12">
  <!-- decorative tang glow under window -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-[60%] -translate-x-1/2 -translate-y-1/2"
    style="width: 80%; height: 60%; background: radial-gradient(ellipse at center, rgba(234,88,12,0.12) 0%, rgba(234,88,12,0.04) 40%, rgba(234,88,12,0) 70%); z-index: 0;"
  >
  </div>

  <div
    class="relative z-10 overflow-hidden rounded-[14px] border border-line-light bg-paper"
    style="box-shadow: 0 30px 60px -20px rgba(234,88,12,0.18), 0 1px 0 rgba(11,11,15,0.04);"
  >
    <!-- tab bar -->
    <div
      class="flex items-stretch border-b border-line-light"
      style="background: #F2EFE9;"
    >
      <div
        class="flex items-center gap-2.5 border-r border-line-light bg-paper px-5 py-3.5 font-mono text-[13px] text-ink"
      >
        <File size={14} class="text-mute" />
        introduction.mdx
      </div>
      <div
        class="border-r border-line-light px-5 py-3.5 font-mono text-[13px] text-mute"
      >
        docs.json
      </div>
      <div class="flex-1"></div>
      <div
        class="flex items-center gap-2 px-5 py-3.5 font-mono text-[13px] text-mute"
      >
        <span
          class="inline-block h-1.5 w-1.5 rounded-full bg-tang-600"
        ></span>
        localhost:4322/introduction
      </div>
    </div>

    <div class="flex">
      <!-- MDX source -->
      <div
        class="flex flex-1 flex-col border-r border-line-light bg-ink p-7 font-mono text-[13.5px] leading-[22px] text-line-light"
      >
        <div><span class="text-mute">---</span></div>
        <div><span class="text-tang-700">title:</span> <span class="text-tang-300">"Introduction"</span></div>
        <div><span class="text-tang-700">description:</span> <span class="text-tang-300">"What Tangly is"</span></div>
        <div><span class="text-mute">---</span></div>
        <div class="h-3.5"></div>
        <div><span class="text-mute"># </span>Self-host your docs.</div>
        <div class="h-1.5"></div>
        <div>Tangly turns Markdown into a fast, themed,</div>
        <div>deployable docs site.</div>
        <div class="h-3.5"></div>
        <div><span class="text-tang-300">&lt;Note&gt;</span></div>
        <div>  Already have Mintlify? <span class="text-tang-300">`tangly dev`</span></div>
        <div>  renders your project as-is.</div>
        <div><span class="text-tang-300">&lt;/Note&gt;</span></div>
        <div class="h-3.5"></div>
        <div><span class="text-mute">## </span>Components</div>
        <div class="h-1.5"></div>
        <div><span class="text-tang-300">&lt;Card</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Install"</span></div>
        <div>  <span class="text-tang-700">icon</span>=<span class="text-tang-300">"terminal"</span></div>
        <div>  <span class="text-tang-700">href</span>=<span class="text-tang-300">"/install"</span><span class="text-tang-300">&gt;</span></div>
        <div>  One-line install via curl.</div>
        <div><span class="text-tang-300">&lt;/Card&gt;</span></div>
        <div class="h-3.5"></div>
        <div><span class="text-tang-300">&lt;Steps&gt;</span></div>
        <div>  <span class="text-tang-300">&lt;Step</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Install"</span><span class="text-tang-300">&gt;</span></div>
        <div>    curl tangly.dev/install.sh | sh</div>
        <div>  <span class="text-tang-300">&lt;/Step&gt;</span></div>
        <div>  <span class="text-tang-300">&lt;Step</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Init"</span><span class="text-tang-300">&gt;</span>tangly init<span class="text-tang-300">&lt;/Step&gt;</span></div>
        <div>  <span class="text-tang-300">&lt;Step</span> <span class="text-tang-700">title</span>=<span class="text-tang-300">"Build"</span><span class="text-tang-300">&gt;</span>tangly build<span class="text-tang-300">&lt;/Step&gt;</span></div>
        <div><span class="text-tang-300">&lt;/Steps&gt;</span></div>
        <div class="h-3.5"></div>
        <div>Status: <span class="text-tang-300">&lt;Badge&gt;</span>stable<span class="text-tang-300">&lt;/Badge&gt;</span></div>
      </div>

      <!-- Rendered -->
      <div class="flex flex-1 flex-col bg-paper px-14 py-12">
        <div
          class="mb-2 font-mono text-[11px] uppercase tracking-[0.04em] text-mute"
        >
          Get started
        </div>
        <h2
          class="font-sans text-[40px] font-semibold leading-[44px] tracking-[-0.025em] text-ink"
        >
          Self-host your docs.
        </h2>
        <div class="h-6"></div>
        <p class="font-sans text-base leading-7 text-line-dark">
          Tangly turns Markdown into a fast, themed, deployable docs site.
        </p>

        <!-- Note callout -->
        <div
          class="mt-6 flex items-start gap-3 rounded-[10px] p-[18px]"
          style="background: rgba(234,88,12,0.05); border: 1px solid rgba(234,88,12,0.18);"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#C2410C"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mt-0.5 shrink-0"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
          <p class="font-sans text-sm leading-[22px] text-line-dark">
            Already have Mintlify? <code
              class="rounded bg-ink/[0.06] px-1.5 py-px font-mono text-[13px] text-ink"
              >tangly dev</code
            > renders your project as-is.
          </p>
        </div>

        <h3
          class="mt-9 font-sans text-2xl font-semibold leading-7 tracking-[-0.015em] text-ink"
        >
          Components
        </h3>

        <!-- Card -->
        <div
          class="mt-4 flex flex-col gap-2 rounded-xl border border-line-light bg-paper p-5"
        >
          <div class="flex items-center gap-2.5">
            <div
              class="flex h-8 w-8 items-center justify-center rounded-lg"
              style="background: rgba(234,88,12,0.08);"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#C2410C"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="4 17 10 11 4 5"></polyline>
                <line x1="12" y1="19" x2="20" y2="19"></line>
              </svg>
            </div>
            <span class="font-sans text-[15px] font-semibold text-ink"
              >Install</span
            >
            <div class="flex-1"></div>
            <span class="font-sans text-sm text-mute">→</span>
          </div>
          <p class="pl-[42px] font-sans text-sm leading-[22px] text-mute">
            One-line install via curl.
          </p>
        </div>

        <!-- Steps -->
        <div
          class="mt-4 flex flex-col gap-3.5 rounded-xl border border-line-light bg-paper p-5"
        >
          {[
            { n: 1, t: "Install", c: "curl tangly.dev/install.sh | sh", active: true },
            { n: 2, t: "Init", c: "tangly init", active: false },
            { n: 3, t: "Build", c: "tangly build", active: false },
          ].map((s) => (
            <div class="flex gap-3.5">
              <div
                class:list={[
                  "flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full font-sans text-[11px] font-semibold",
                  s.active
                    ? "bg-tang-600 text-paper"
                    : "border border-line-light text-mute",
                ]}
              >
                {s.n}
              </div>
              <div class="flex flex-col gap-0.5">
                <div class="font-sans text-sm font-semibold text-ink">
                  {s.t}
                </div>
                <code class="font-mono text-xs text-mute">{s.c}</code>
              </div>
            </div>
          ))}
        </div>

        <!-- Badge inline -->
        <div class="mt-4 flex items-center gap-2">
          <span class="font-sans text-sm text-line-dark">Status:</span>
          <span
            class="inline-flex items-center rounded-full px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase tracking-[0.04em] text-tang-700"
            style="background: rgba(234,88,12,0.08); border: 1px solid rgba(234,88,12,0.20);"
          >
            stable
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

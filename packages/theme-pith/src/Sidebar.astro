---
import type { DocsJson } from "@tanglydocs/schema";
import type { ResolvedNavigation, SidebarItem } from "@tanglydocs/tangly";
import Icon from "@tanglydocs/theme-ui/components/Icon.astro";

/**
 * Pith's full-chrome sidebar. No separate top bar, so this hosts logo,
 * search, theme toggle, tabs, anchors, navbar links, and the primary
 * CTA — plus the navigation tree itself.
 *
 * The component recurses via `Astro.self` to render nested groups. The
 * outer call (`_treeOnly` falsy) renders the chrome + tab layout; nested
 * calls (`_treeOnly` true) render just the unordered nav list.
 */
export interface Props {
  config: DocsJson;
  navigation: ResolvedNavigation;
  currentTabSlug?: string;
  items: SidebarItem[];
  currentSlug: string;
  /** Internal recursion guard — true skips chrome and renders only the tree. */
  _treeOnly?: boolean;
  /** Internal recursion depth (for left-padding). */
  _depth?: number;
}

const {
  config,
  navigation,
  currentTabSlug,
  items,
  currentSlug,
  _treeOnly = false,
  _depth = 0,
} = Astro.props as Props;

const logoLight =
  typeof config.logo === "string"
    ? config.logo
    : (config.logo?.light ?? config.logo?.dark);
const logoDark =
  typeof config.logo === "string"
    ? config.logo
    : (config.logo?.dark ?? config.logo?.light);
const logoHref = typeof config.logo === "string" ? "/" : (config.logo?.href ?? "/");

const tabs = navigation.tabs;
const anchors = navigation.anchors;
const navbarLinks = config.navbar?.links ?? [];
const primary = config.navbar?.primary;
---
{_treeOnly ? (
  <ul class="space-y-0.5">
    {items.map((item) => (
      <li>
        {item.isGroup ? (
          <details open={item.expanded ?? true} class="group/det">
            <summary class={`flex items-center gap-1.5 cursor-pointer list-none select-none py-1.5 px-2 rounded-md text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] ${_depth === 0 ? "text-xs font-semibold uppercase tracking-wide" : "text-sm"}`}>
              <span class="inline-flex transition-transform group-open/det:rotate-90">
                <Icon icon="ChevronRight" size={12} />
              </span>
              {item.icon && <Icon icon={item.icon} size={14} />}
              <span class="flex-1">{item.title}</span>
              {item.tag && (
                <span class="ml-1 text-[10px] font-medium uppercase tracking-wide rounded-full px-1.5 py-0.5 bg-[var(--tangly-color-bg-elevated)] text-[var(--tangly-color-muted)] border border-[var(--tangly-color-border)]">
                  {item.tag}
                </span>
              )}
            </summary>
            <div class="mt-0.5 ml-1 pl-3 border-l border-[var(--tangly-color-border)]">
              <Astro.self
                config={config}
                navigation={navigation}
                items={item.children ?? []}
                currentSlug={currentSlug}
                _treeOnly={true}
                _depth={_depth + 1}
              />
            </div>
          </details>
        ) : (
          <a
            href={`/${item.slug}`}
            data-active={item.slug === currentSlug ? "true" : "false"}
            class="tangly-side-link flex items-center gap-2 px-2 py-1.5 rounded-md text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] hover:bg-[var(--tangly-color-bg-elevated)] no-underline text-sm"
          >
            {item.icon ? <Icon icon={item.icon} size={14} /> : <span class="w-3.5 inline-block"></span>}
            <span class="flex-1 truncate">{item.title}</span>
            {item.tag && (
              <span class="text-[10px] font-medium uppercase tracking-wide rounded-full px-1.5 py-0.5 bg-[var(--tangly-color-bg-elevated)] text-[var(--tangly-color-muted)] border border-[var(--tangly-color-border)]">
                {item.tag}
              </span>
            )}
          </a>
        )}
      </li>
    ))}
  </ul>
) : (
  <div class="flex flex-col gap-5 px-5 py-6 h-full min-h-0">
    {/* Logo */}
    <a href={logoHref} class="flex items-center gap-2 font-semibold text-[var(--tangly-color-fg)] no-underline">
      {logoLight && (
        <img src={logoLight} alt={config.name} class="h-8 w-auto block dark:hidden" />
      )}
      {logoDark && (
        <img src={logoDark} alt={config.name} class="h-8 w-auto hidden dark:block" />
      )}
      {!logoLight && !logoDark && <span class="text-lg">{config.name}</span>}
    </a>

    {/* Search — uses a data attribute (not an id) because Pith's Layout
        renders this Sidebar twice (desktop aside + mobile drawer); a
        global id would collide and only one button would get the
        listener. */}
    <button
      type="button"
      data-tangly-search
      class="inline-flex items-center gap-2 h-9 px-3 rounded-md border border-[var(--tangly-color-border)] bg-[var(--tangly-color-bg-elevated)] text-sm text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] w-full"
      aria-label="Search docs"
    >
      <Icon icon="Search" size={14} />
      <span>Search</span>
      <span class="ml-auto inline-flex items-center gap-0.5 text-[10px]">
        <kbd class="px-1.5 py-0.5 border border-[var(--tangly-color-border)] rounded">⌘</kbd>
        <kbd class="px-1.5 py-0.5 border border-[var(--tangly-color-border)] rounded">K</kbd>
      </span>
    </button>

    {/* Tabs as section headers — pith renders each tab's nav inline. */}
    <div class="flex flex-col gap-5 flex-1 min-h-0 overflow-y-auto tangly-scroll -mx-1 px-1">
      {tabs.length > 1 ? (
        tabs.map((t) => (
          <section data-tab-slug={t.slug}>
            <a
              href={t.href ?? (t.pages[0] ? `/${t.pages[0]}` : `/${t.slug}`)}
              data-active={t.slug === currentTabSlug ? "true" : "false"}
              class="flex items-center gap-1.5 mb-2 px-2 text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--tangly-color-muted)] data-[active=true]:text-[var(--tangly-color-primary)] hover:text-[var(--tangly-color-fg)] no-underline"
            >
              {t.icon && <Icon icon={t.icon} size={12} />}
              <span>{t.title}</span>
            </a>
            {t.slug === currentTabSlug && (
              <Astro.self
                config={config}
                navigation={navigation}
                items={t.sidebar}
                currentSlug={currentSlug}
                _treeOnly={true}
                _depth={0}
              />
            )}
          </section>
        ))
      ) : (
        <Astro.self
          config={config}
          navigation={navigation}
          items={items}
          currentSlug={currentSlug}
          _treeOnly={true}
          _depth={0}
        />
      )}
    </div>

    {/* Bottom rail */}
    <div class="pt-4 mt-2 border-t border-[var(--tangly-color-border)] flex flex-col gap-1">
      {anchors.map((a) => (
        <a
          href={a.href}
          class="inline-flex items-center gap-2 text-sm text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] py-1 no-underline"
        >
          {a.icon && <Icon icon={a.icon} size={14} />}
          <span>{a.title}</span>
        </a>
      ))}
      {navbarLinks.map((l) => (
        <a
          href={l.href}
          class="inline-flex items-center gap-2 text-sm text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] py-1 no-underline"
        >
          {typeof l.icon === "string" && <Icon icon={l.icon} size={14} />}
          <span>{l.label}</span>
        </a>
      ))}
      <button
        type="button"
        data-tangly-theme-toggle
        class="inline-flex items-center gap-2 text-sm text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] py-1"
        aria-label="Toggle theme"
      >
        <span class="dark:hidden inline-flex items-center gap-2">
          <Icon icon="Moon" size={14} /><span>Dark</span>
        </span>
        <span class="hidden dark:inline-flex items-center gap-2">
          <Icon icon="Sun" size={14} /><span>Light</span>
        </span>
      </button>
      {primary && primary.type === "button" && (
        <a
          href={primary.href}
          class="mt-1 inline-flex items-center justify-center h-9 px-3.5 rounded-md text-sm font-medium text-white shrink-0 hover:opacity-90 no-underline"
          style="background: var(--tangly-color-primary)"
        >
          {primary.label}
        </a>
      )}
      {primary && primary.type === "github" && (
        <a
          href={primary.href}
          class="inline-flex items-center gap-2 text-sm text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] py-1 no-underline"
          aria-label="GitHub"
        >
          <Icon icon="Github" size={14} />
          <span>GitHub</span>
        </a>
      )}
    </div>

    <script is:inline data-tangly-pith-sidebar-init>
      // Idempotent across multiple Sidebar instances (desktop + mobile
      // drawer). Each script tag self-marks; the first one to run wires
      // up *every* matching control via querySelectorAll, the rest are
      // no-ops.
      (() => {
        if (window.__tanglyPithSidebarInit) return;
        window.__tanglyPithSidebarInit = true;
        document.querySelectorAll("[data-tangly-search]").forEach((el) => {
          el.addEventListener("click", () => {
            document.dispatchEvent(new CustomEvent("tangly:open-search"));
          });
        });
        document.querySelectorAll("[data-tangly-theme-toggle]").forEach((el) => {
          el.addEventListener("click", () => {
            document.dispatchEvent(new CustomEvent("tangly:toggle-theme"));
          });
        });
      })();
    </script>
  </div>
)}

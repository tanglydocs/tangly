---
import { manifest } from "virtual:tangly/manifest";

/**
 * Embed a labeled block from another page.
 *
 *   <Embed page="billing" block="rate-limits" />
 *
 * `page` is a page slug (no leading slash).
 * `block` is either an auto-generated heading ID or an explicit `{#id}`
 *  marker captured by the manifest's block extractor.
 *
 * Phase 5 renders the block as Markdown only — no MDX/JSX components in
 * embedded fragments. Cycle detection runs in a per-render stack tracked
 * on globalThis. Build fails with a clear error pointing at both files
 * when a cycle is found.
 */
export interface Props {
  page: string;
  block: string;
}

const { page: pageSlug, block: blockId } = Astro.props as Props;

interface EmbedStack {
  stack: Array<{ page: string; block: string }>;
}
const G = globalThis as { __TANGLY_EMBED__?: EmbedStack };
G.__TANGLY_EMBED__ ??= { stack: [] };
const embedStack = G.__TANGLY_EMBED__.stack;

// Detect cycle BEFORE pushing so the failing pair surfaces in the error.
const cycle = embedStack.find(
  (e) => e.page === pageSlug && e.block === blockId,
);
if (cycle) {
  const trail = embedStack
    .map((e) => `${e.page}#${e.block}`)
    .concat(`${pageSlug}#${blockId}`)
    .join(" → ");
  throw new Error(
    `[tangly] Circular <Embed> detected: ${trail}. ` +
      `Break the cycle by inlining one block or removing one embed.`,
  );
}

const pageEntry = manifest.pages.find(([s]) => s === pageSlug)?.[1];

let html: string | null = null;
let error: string | null = null;

if (!pageEntry) {
  error = `Page "${pageSlug}" not found in manifest.`;
} else {
  const blocks = (pageEntry as unknown as { blocks?: Record<string, string> })
    .blocks;
  const source = blocks?.[blockId];
  if (!source) {
    error =
      `Block "${blockId}" not found on page "${pageSlug}". ` +
      `Available: ${Object.keys(blocks ?? {}).join(", ") || "(none)"}.`;
  } else {
    embedStack.push({ page: pageSlug, block: blockId });
    try {
      // Render block source as Markdown -> HTML. We deliberately don't go
      // through MDX/JSX here — embeds are content fragments, not components.
      // remark-gfm covers tables/strikethrough/task lists/etc.
      const { unified } = await import("unified");
      const { default: remarkParse } = await import("remark-parse");
      const { default: remarkGfm } = await import("remark-gfm");
      const { default: remarkRehype } = await import("remark-rehype");
      const { default: rehypeStringify } = await import("rehype-stringify");
      const file = await unified()
        .use(remarkParse)
        .use(remarkGfm)
        .use(remarkRehype, { allowDangerousHtml: true })
        .use(rehypeStringify, { allowDangerousHtml: true })
        .process(source);
      html = String(file);
    } catch (err) {
      error = `Failed to render block "${blockId}": ${(err as Error).message}`;
    } finally {
      embedStack.pop();
    }
  }
}
---

{error ? (
  <div class="my-4 rounded-lg border border-rose-300 bg-rose-50 px-4 py-3 text-sm text-rose-800 dark:bg-rose-950/40 dark:border-rose-800 dark:text-rose-200">
    <strong class="font-semibold">Embed error:</strong> {error}
  </div>
) : (
  <div class="tangly-embed" data-embed-page={pageSlug} data-embed-block={blockId}>
    <Fragment set:html={html ?? ""} />
    <a
      href={`/${pageSlug}#${blockId}`}
      class="text-xs text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] inline-flex items-center gap-1 mt-2 no-underline"
      aria-label="View source"
    >
      → View in /{pageSlug}
    </a>
  </div>
)}

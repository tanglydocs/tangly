---
/**
 * Full-viewport branded loading splash. Shown on the root index route while it
 * forwards to the first content page (see runtime `pages/index.astro`), and
 * reusable anywhere a themed "loading" state is wanted.
 *
 * Theme-agnostic: every colour/font comes from `--tangly-*` CSS vars, so it
 * adopts whichever theme is active (tang, pith, …) with no per-theme code.
 * Shows the logo when set (usually a wordmark carrying the name) and falls
 * back to the site name otherwise; an accent-coloured dot pulse sits beneath.
 */
import type { DocsJson } from "@tanglydocs/schema";

export interface Props {
  config: DocsJson;
}

const { config } = Astro.props as Props;

// Mirror TopNav's logo resolution (raw URLs; static middleware serves them).
const logoLight =
  typeof config.logo === "string" ? config.logo : (config.logo?.light ?? config.logo?.dark);
const logoDark =
  typeof config.logo === "string" ? config.logo : (config.logo?.dark ?? config.logo?.light);
const hasLogo = Boolean(logoLight || logoDark);
---

<div class="tangly-splash">
  <div class="tangly-splash-inner">
    {hasLogo ? (
      <span class="tangly-splash-logo">
        {logoLight && <img src={logoLight} alt={config.name} class="tangly-splash-logo-light" />}
        {logoDark && <img src={logoDark} alt={config.name} class="tangly-splash-logo-dark" />}
      </span>
    ) : (
      <span class="tangly-splash-name">{config.name}</span>
    )}

    <span class="tangly-splash-loader" role="status" aria-label={`Loading ${config.name}`}>
      <span class="tangly-splash-dot"></span>
      <span class="tangly-splash-dot"></span>
      <span class="tangly-splash-dot"></span>
    </span>
  </div>
</div>

<style>
  .tangly-splash {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: var(--tangly-color-bg, #fafaf7);
    color: var(--tangly-color-fg, #0b0b0f);
  }

  .tangly-splash-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    /* Lift slightly above dead centre — reads as more deliberate. */
    transform: translateY(-4%);
    animation: tangly-splash-in 0.4s ease-out both;
  }

  .tangly-splash-logo img {
    height: 2.5rem;
    width: auto;
    display: block;
  }
  /* Light/dark logo swap via the root `.dark` class. Done in scoped CSS rather
     than Tailwind `dark:` utilities so the splash never depends on a theme's
     content-scanner config (those utilities aren't generated for this file).
     The `img.` compound keeps specificity above the `.tangly-splash-logo img`
     base rule that sets `display: block`. */
  .tangly-splash-logo img.tangly-splash-logo-dark {
    display: none;
  }
  :global(html.dark) .tangly-splash-logo img.tangly-splash-logo-light {
    display: none;
  }
  :global(html.dark) .tangly-splash-logo img.tangly-splash-logo-dark {
    display: block;
  }

  .tangly-splash-name {
    font-family: var(--tangly-font-heading, system-ui, sans-serif);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .tangly-splash-loader {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .tangly-splash-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: var(--tangly-color-primary, #ea580c);
    animation: tangly-splash-bounce 1.1s ease-in-out infinite both;
  }
  .tangly-splash-dot:nth-child(1) { animation-delay: -0.24s; }
  .tangly-splash-dot:nth-child(2) { animation-delay: -0.12s; }
  .tangly-splash-dot:nth-child(3) { animation-delay: 0s; }

  @keyframes tangly-splash-bounce {
    0%, 80%, 100% { transform: scale(0.5); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  @keyframes tangly-splash-in {
    from { opacity: 0; transform: translateY(0); }
    to { opacity: 1; transform: translateY(-4%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .tangly-splash-inner { animation: none; }
    .tangly-splash-dot {
      animation: tangly-splash-pulse 1.4s ease-in-out infinite both;
    }
    @keyframes tangly-splash-pulse {
      0%, 100% { opacity: 0.35; }
      50% { opacity: 1; }
    }
  }
</style>

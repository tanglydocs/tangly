---
// CodeGroup wraps multiple code blocks (e.g. <pre>) and renders them as tabs.
// Tab labels come from each child's `data-filename` or `data-language` attribute,
// or fall back to "Tab N". Switching is handled by a tiny inline script.

export interface Props {}

const groupId = `cg-${Math.random().toString(36).slice(2, 9)}`;
---
<div class="tangly-code-group rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 my-4" data-code-group={groupId}>
  <div class="tangly-code-tabs flex items-center gap-1 px-2 pt-2 border-b border-zinc-200 dark:border-zinc-800 overflow-x-auto" role="tablist"></div>
  <div class="tangly-code-panels"><slot /></div>
</div>
<script is:inline define:vars={{ groupId }}>
  (function () {
    const root = document.querySelector(`[data-code-group="${groupId}"]`);
    if (!root) return;
    const panels = root.querySelector(".tangly-code-panels");
    const tabsBar = root.querySelector(".tangly-code-tabs");
    if (!panels || !tabsBar) return;
    const blocks = Array.from(panels.children);
    blocks.forEach((blk, i) => {
      const el = blk;
      const filename = el.getAttribute("data-filename") || el.getAttribute("filename");
      const lang = el.getAttribute("data-language") || el.getAttribute("data-lang");
      const codeEl = el.querySelector("code");
      const codeLang = codeEl?.className.match(/language-([\w-]+)/)?.[1];
      const label = filename || lang || codeLang || `Tab ${i + 1}`;
      const btn = document.createElement("button");
      btn.type = "button";
      btn.textContent = label;
      btn.setAttribute("role", "tab");
      btn.className =
        "px-3 py-1.5 text-xs font-medium rounded-md text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors";
      btn.dataset.idx = String(i);
      btn.addEventListener("click", () => activate(i));
      tabsBar.appendChild(btn);
      el.classList.add("tangly-code-panel");
      if (i !== 0) el.style.display = "none";
    });
    function activate(idx) {
      Array.from(tabsBar.children).forEach((b, i) => {
        const btn = b;
        if (i === idx) {
          btn.classList.add("bg-white", "dark:bg-zinc-800", "text-zinc-900", "dark:text-zinc-100", "shadow-sm");
        } else {
          btn.classList.remove("bg-white", "dark:bg-zinc-800", "text-zinc-900", "dark:text-zinc-100", "shadow-sm");
        }
      });
      blocks.forEach((b, i) => {
        b.style.display = i === idx ? "" : "none";
      });
    }
    activate(0);
  })();
</script>

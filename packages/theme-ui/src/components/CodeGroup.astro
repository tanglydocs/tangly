---
// CodeGroup wraps multiple code blocks (e.g. <pre> or <figure>) and renders
// them as tabs. Tab labels come from each child's `data-filename`,
// `data-language`, or `data-language` on the inner pre, falling back to
// "Tab N".
//
// Sync: pass `name=` and every group with that name shows the same active
// tab (persisted in localStorage). When `name` is empty, the runtime
// auto-derives one from the labels — npm/yarn/pnpm/bun, pip/uv, macOS/
// Linux/Windows, python/typescript, ... all sync without explicit naming.

export interface Props {
  /** Optional sync key. Same `name` across blocks → matched tab.
   *  Leave empty to auto-derive from a known label family. */
  name?: string;
}

const { name = "" } = Astro.props as Props;
const groupId = `cg-${Math.random().toString(36).slice(2, 9)}`;
---
<div
  class="tangly-code-group rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 my-4"
  data-code-group={groupId}
  data-code-group-name={name || undefined}
>
  <div class="tangly-code-tabs flex items-center gap-1 px-2 pt-2 border-b border-zinc-200 dark:border-zinc-800 overflow-x-auto" role="tablist"></div>
  <div class="tangly-code-panels"><slot /></div>
</div>
<script is:inline define:vars={{ groupId, name }}>
  (function () {
    const root = document.querySelector(`[data-code-group="${groupId}"]`);
    if (!root) return;
    const panels = root.querySelector(".tangly-code-panels");
    const tabsBar = root.querySelector(".tangly-code-tabs");
    if (!panels || !tabsBar) return;
    const blocks = Array.from(panels.children);
    const labels = [];

    // Mutable holder so the click handler can read the latest sync name
    // even if it's resolved asynchronously (deriveName runs once the
    // sync registry script has loaded).
    const state = { name: name };

    blocks.forEach((blk, i) => {
      const el = blk;
      const innerPre = el.tagName === "PRE" ? el : el.querySelector("pre");
      const filename =
        el.getAttribute("data-filename") ||
        innerPre?.getAttribute("data-filename") ||
        el.getAttribute("filename");
      const lang =
        el.getAttribute("data-language") ||
        innerPre?.getAttribute("data-language") ||
        el.getAttribute("data-lang");
      const codeEl = (innerPre ?? el).querySelector("code");
      const codeLang = codeEl?.className.match(/language-([\w-]+)/)?.[1];
      const label = filename || lang || codeLang || `Tab ${i + 1}`;
      labels.push(label);
      const btn = document.createElement("button");
      btn.type = "button";
      btn.textContent = label;
      btn.setAttribute("role", "tab");
      btn.className =
        "px-3 py-1.5 text-xs font-medium rounded-md text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors";
      btn.dataset.idx = String(i);
      btn.addEventListener("click", () => {
        activate(i);
        if (state.name && window.__tanglyCodeGroup) {
          window.__tanglyCodeGroup.onActivate(groupId, state.name, label);
        }
      });
      tabsBar.appendChild(btn);
      el.classList.add("tangly-code-panel");
      if (i !== 0) el.style.display = "none";
    });

    function activate(idx) {
      Array.from(tabsBar.children).forEach((b, i) => {
        const btn = b;
        if (i === idx) {
          btn.classList.add("bg-white", "dark:bg-zinc-800", "text-zinc-900", "dark:text-zinc-100", "shadow-sm");
        } else {
          btn.classList.remove("bg-white", "dark:bg-zinc-800", "text-zinc-900", "dark:text-zinc-100", "shadow-sm");
        }
      });
      blocks.forEach((b, i) => {
        b.style.display = i === idx ? "" : "none";
      });
    }
    activate(0);

    const tryRegister = () => {
      if (!window.__tanglyCodeGroup) {
        setTimeout(tryRegister, 50);
        return;
      }
      if (!state.name) {
        state.name = window.__tanglyCodeGroup.deriveName(labels);
      }
      if (state.name) {
        window.__tanglyCodeGroup.register(groupId, state.name, labels, activate);
      }
    };
    tryRegister();
  })();
</script>

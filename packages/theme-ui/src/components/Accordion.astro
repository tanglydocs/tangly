---
import Icon from "./Icon.astro";

export interface Props {
  title: string;
  defaultOpen?: boolean;
  icon?: string;
  description?: string;
}

const { title, defaultOpen = false, icon, description } = Astro.props as Props;
---
<details
  class="tangly-accordion group rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 my-2 overflow-hidden"
  open={defaultOpen}
>
  <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden hover:bg-zinc-50 dark:hover:bg-zinc-800/50">
    {icon && (
      <span class="shrink-0 text-zinc-600 dark:text-zinc-400">
        <Icon icon={icon} size={16} />
      </span>
    )}
    <div class="flex-1 min-w-0">
      <div class="font-medium text-zinc-900 dark:text-zinc-100 text-sm">{title}</div>
      {description && (
        <div class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">{description}</div>
      )}
    </div>
    <span class="shrink-0 text-zinc-500 dark:text-zinc-400 transition-transform duration-200 group-open:rotate-90">
      <Icon icon="chevron-right" size={16} />
    </span>
  </summary>
  <div class="px-4 pt-2 pb-4 text-sm text-zinc-700 dark:text-zinc-300 leading-relaxed border-t border-zinc-200 dark:border-zinc-800 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0">
    <slot />
  </div>
</details>

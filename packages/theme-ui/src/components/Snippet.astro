---
// TODO(phase-2): resolve `<projectRoot>/snippets/<file>` and render the MDX
// at build time via Astro.glob/import.meta.glob. For Phase 1, this is a
// placeholder that renders any inline children passed via <slot />.
export interface Props {
  file: string;
}

const { file } = Astro.props as Props;
---
<div class="tangly-snippet" data-snippet-file={file}>
  <slot />
</div>

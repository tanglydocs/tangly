---
import EndpointAuthorizations from "./openapi/EndpointAuthorizations.astro";
import EndpointDescription from "./openapi/EndpointDescription.astro";
import EndpointHeader from "./openapi/EndpointHeader.astro";
import EndpointPanel from "./openapi/EndpointPanel.astro";
import EndpointParameters from "./openapi/EndpointParameters.astro";
import EndpointRequestBody from "./openapi/EndpointRequestBody.astro";
import EndpointResponses from "./openapi/EndpointResponses.astro";
import { exampleFromSchema } from "./openapi/_example-from-schema.ts";
import { resolveAuth, type AuthMethod } from "./openapi/_security.ts";
import { loadSpec } from "./openapi/_spec-loader.ts";

/**
 * Renders one OpenAPI operation: docs column on the left, sticky
 * playground panel on the right. The split layout activates when the
 * page is in `mode: "api"`; on other pages it falls back to a
 * single-column inline render.
 */
export interface Props {
  spec: string;
  method: string;
  path: string;
  baseUrl?: string;
  authMethod?: AuthMethod;
  authName?: string;
  /** Languages to render in the right-rail panel. */
  languages?: string[];
  /** Spec-level x-codeSamples (passed through from manifest). */
  specSamples?: Array<{ lang: string; label?: string; source: string }>;
  /** Playground mode override (frontmatter `playground` or `api.playground.mode`). */
  playgroundMode?: "interactive" | "simple" | "hide";
  /** Forward credentials on cross-origin try-it requests. */
  credentials?: boolean;
  /** Default expansion state for parameter rows. */
  paramsExpanded?: "all" | "closed";
  /** OpenAPI fields to surface as pills. */
  paramsPost?: string[];
  /** Show full URL in header rather than just path. */
  showFullUrl?: boolean;
  /** Pull example values from spec into samples. Default true. */
  prefill?: boolean;
  /** Sample includes only required params or all of them. Default required. */
  defaults?: "required" | "all";
  /** Layout: inline (single column) or split (docs + panel grid). */
  layout?: "inline" | "split";
  /**
   * Pre-resolved schema (already dereffed) used as the response shape
   * when an operation's response has empty `schema: {}`. Threaded from
   * `api.responseFallback` by the dispatcher.
   */
  fallbackResponseSchema?: Record<string, unknown>;
}

const {
  spec,
  method,
  path,
  baseUrl,
  authMethod,
  authName,
  languages = ["curl", "typescript", "python"],
  specSamples,
  playgroundMode = "interactive",
  credentials,
  paramsExpanded: _paramsExpanded,
  paramsPost,
  showFullUrl,
  prefill,
  defaults,
  layout = "inline",
  fallbackResponseSchema,
} = Astro.props as Props;
// `paramsExpanded` is no longer surfaced (rows always render expanded).
void _paramsExpanded;

const methodLower = method.toLowerCase();
const { op, servers, securitySchemes, loadError } = await loadSpec(spec, methodLower, path);

const effectiveBaseUrl = baseUrl ?? servers[0] ?? "";
const auth = resolveAuth({
  op,
  schemes: securitySchemes,
  ...(authMethod && { override: authMethod }),
  ...(authName && { overrideName: authName }),
});

const isSplit = layout === "split" && playgroundMode !== "hide" && op !== null;

// Pre-compute response examples per code for the right-rail panel. The
// fallbackResponseSchema substitutes for empty `{}` 2xx schemas.
const responseExamplesByCode: Record<string, unknown> = {};
if (op?.responses) {
  for (const [code, info] of Object.entries(op.responses)) {
    const json = info.content?.["application/json"];
    let schema: unknown = json?.schema;
    const isEmpty =
      schema && typeof schema === "object" && Object.keys(schema as object).length === 0;
    const is2xx = parseInt(code, 10) >= 200 && parseInt(code, 10) < 300;
    if (isEmpty && is2xx && fallbackResponseSchema) schema = fallbackResponseSchema;
    if (schema) {
      const ex = exampleFromSchema(schema);
      if (ex !== null && ex !== undefined) responseExamplesByCode[code] = ex;
    }
  }
}
---

{loadError ? (
  <p class="text-sm text-rose-500">{loadError}</p>
) : op ? (
  <div class={isSplit ? "tangly-openapi-split grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_var(--tangly-api-panel-width,380px)] xl:gap-8" : ""}>
    <div class="min-w-0">
      <EndpointHeader
        method={methodLower}
        path={path}
        baseUrl={effectiveBaseUrl}
        showFullUrl={showFullUrl}
        showTryIt={isSplit && playgroundMode === "interactive"}
      />
      <EndpointDescription description={op.description} />
      <EndpointAuthorizations auth={auth} />
      {Array.isArray(op.parameters) && op.parameters.length > 0 ? (
        <EndpointParameters parameters={op.parameters} extraPills={paramsPost} />
      ) : null}
      {op.requestBody &&
      !((methodLower === "get" || methodLower === "head") && !op.requestBody.required) ? (
        <EndpointRequestBody requestBody={op.requestBody} />
      ) : null}
      {op.responses && Object.keys(op.responses).length > 0 ? (
        <EndpointResponses
          responses={op.responses}
          {...(fallbackResponseSchema && { fallbackSchema: fallbackResponseSchema })}
          {...(isSplit && { hideExample: true })}
        />
      ) : null}
    </div>
    {isSplit ? (
      <div class="xl:sticky xl:top-[calc(var(--tangly-topnav-height,56px)+1.5rem)] xl:self-start mt-6 xl:mt-0">
        <EndpointPanel
          op={op}
          method={methodLower}
          path={path}
          baseUrl={effectiveBaseUrl}
          auth={auth}
          languages={languages}
          {...(specSamples && { specSamples })}
          playgroundMode={playgroundMode}
          {...(credentials !== undefined && { credentials })}
          {...(prefill !== undefined && { prefill })}
          {...(defaults && { defaults })}
          {...(op.summary && { title: op.summary })}
          responseExamplesByCode={responseExamplesByCode}
        />
      </div>
    ) : (
      playgroundMode !== "hide" ? (
        <div class="mt-6">
          <EndpointPanel
            op={op}
            method={methodLower}
            path={path}
            baseUrl={effectiveBaseUrl}
            auth={auth}
            languages={languages}
            {...(specSamples && { specSamples })}
            playgroundMode={playgroundMode}
            {...(credentials !== undefined && { credentials })}
            {...(prefill !== undefined && { prefill })}
            {...(defaults && { defaults })}
          />
        </div>
      ) : null
    )}
  </div>
) : (
  <p class="text-sm text-zinc-600 dark:text-zinc-400">No data for this endpoint.</p>
)}

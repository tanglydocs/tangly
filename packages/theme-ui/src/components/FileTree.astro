---
// FileTree renders a directory tree from a nested Markdown unordered list.
// Usage:
//   <FileTree>
//     - src
//       - components
//         - Button.tsx
//         - **Card.tsx** (highlighted via bold)
//     - package.json
//   </FileTree>
//
// Indentation is preserved by the slot's nested <ul> structure. File icons
// are derived from extensions (using the same lucide names as code-block
// titles); items wrapped in <strong>...</strong> get a highlighted row.
---
<div class="tangly-filetree">
  <slot />
</div>

<style is:global>
.tangly-filetree {
  font-family: var(--tangly-font-mono, "JetBrains Mono"), ui-monospace, monospace;
  font-size: 0.85rem;
  margin: 1rem 0;
  padding: 0.875rem 1rem;
  border: 1px solid var(--tangly-color-border, #e5e7eb);
  border-radius: 0.625rem;
  background: rgba(0, 0, 0, 0.015);
}
.dark .tangly-filetree {
  background: rgba(255, 255, 255, 0.02);
  border-color: rgba(255, 255, 255, 0.06);
}
.tangly-filetree ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
.tangly-filetree ul ul {
  margin-left: 1rem;
  border-left: 1px dashed rgba(0, 0, 0, 0.1);
  padding-left: 0.65rem;
}
.dark .tangly-filetree ul ul {
  border-left-color: rgba(255, 255, 255, 0.1);
}
.tangly-filetree li {
  position: relative;
  padding: 0.05rem 0;
  color: var(--tangly-color-fg);
}
.tangly-filetree li::before {
  content: "├ ";
  color: rgba(0, 0, 0, 0.25);
  margin-right: 0.15rem;
}
.dark .tangly-filetree li::before {
  color: rgba(255, 255, 255, 0.25);
}
.tangly-filetree li strong {
  font-weight: 600;
  background: rgba(56, 189, 248, 0.18);
  border-radius: 0.25rem;
  padding: 0 0.25rem;
}
</style>

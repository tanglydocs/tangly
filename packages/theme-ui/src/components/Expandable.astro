---
import Icon from "./Icon.astro";

export interface Props {
  title: string;
  defaultOpen?: boolean;
}

const { title, defaultOpen = false } = Astro.props as Props;
---
<details
  class="tangly-expandable group my-2 rounded-md border border-dashed border-zinc-200 dark:border-zinc-800"
  open={defaultOpen}
>
  <summary class="flex items-center gap-2 px-3 py-2 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden text-sm text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100">
    <span class="text-zinc-600 dark:text-zinc-400 transition-transform duration-200 group-open:rotate-90">
      <Icon icon="chevron-right" size={14} />
    </span>
    <span class="font-medium">{title}</span>
  </summary>
  <div class="px-4 pb-3 pt-1 text-sm text-zinc-700 dark:text-zinc-300 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0">
    <slot />
  </div>
</details>

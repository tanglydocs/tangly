---
import { withBase } from "../with-base.ts";
import Icon from "./Icon.astro";

export interface Props {
  title?: string;
  icon?: string;
  href?: string;
  horizontal?: boolean;
  img?: string;
  /** Same as `img` — Mintlify-compatible alias used in newer projects. */
  image?: string;
  /** CSS aspect ratio for the image area (e.g. "16/9"). Defaults to 16/9. */
  imageAspect?: string;
  color?: string;
}

const {
  title,
  icon,
  href,
  horizontal = false,
  img,
  image,
  imageAspect = "16/9",
  color,
} = Astro.props as Props;
const resolvedImage = img ?? image;
const Tag = href ? "a" : "div";
const hover = href ? "hover:border-zinc-300 hover:shadow-sm dark:hover:border-zinc-700 transition-colors" : "";
const layout = horizontal ? "flex flex-row items-start gap-4" : "flex flex-col gap-2";
const accent = color ? `style="--card-accent: ${color}"` : "";
---
<Tag
  href={withBase(href)}
  class={`group block rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5 ${hover} no-underline`}
  style={color ? `--card-accent: ${color}` : undefined}
>
  {resolvedImage && (
    <div
      class={horizontal ? "shrink-0 w-32 overflow-hidden rounded-lg" : "mb-3 w-full overflow-hidden rounded-lg"}
      style={`aspect-ratio: ${horizontal ? "4/3" : imageAspect};`}
    >
      <img src={resolvedImage} alt={title ?? ""} class="w-full h-full object-cover" loading="lazy" />
    </div>
  )}
  <div class={layout + " w-full"}>
    {icon && (
      <div
        class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-200"
        style={color ? `color: ${color}` : undefined}
      >
        <Icon icon={icon} size={18} />
      </div>
    )}
    <div class="flex-1 min-w-0">
      {title && (
        <div class="font-semibold text-zinc-900 dark:text-zinc-100 mb-1">{title}</div>
      )}
      <div class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</Tag>

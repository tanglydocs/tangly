---
import { resolveMethodColor } from "../_openapi.ts";

export interface Props {
  method: string;
  path: string;
  baseUrl?: string;
  /** When true, prefix the segments with the base URL. */
  showFullUrl?: boolean;
  /** Render an inline "Try it" button that reveals the playground panel. */
  showTryIt?: boolean;
}

const { method, path, baseUrl, showFullUrl, showTryIt } = Astro.props as Props;
const color = resolveMethodColor(method);

// Break the path into `/`-delimited segments so each renders as its own
// breadcrumb chip (Mintlify style). Param segments keep their {braces}.
type Segment = { kind: "literal"; text: string } | { kind: "param"; name: string };
const segments: Segment[] = path
  .split("/")
  .filter((s) => s.length > 0)
  .map((seg) => {
    const m = seg.match(/^\{(.+)\}$/);
    return m ? { kind: "param", name: m[1]! } : { kind: "literal", text: seg };
  });

const base = showFullUrl && baseUrl ? baseUrl.replace(/\/+$/, "") : "";
---

<div class="tangly-openapi-header flex items-center gap-3 mb-4 not-prose flex-wrap">
  <span
    class="inline-flex items-center justify-center px-2 py-0.5 rounded text-xs font-mono font-semibold uppercase text-white shrink-0"
    style={`background:${color}`}
  >
    {method.toUpperCase()}
  </span>
  <code class="flex items-center flex-wrap gap-1 text-sm font-mono">
    {base ? <span class="text-zinc-600 dark:text-zinc-400">{base}</span> : null}
    {segments.map((seg) => (
      <Fragment>
        <span class="text-zinc-300 dark:text-zinc-600 select-none">/</span>
        {seg.kind === "param" ? (
          <span
            class="inline-flex items-center px-1.5 py-0.5 rounded bg-amber-100 dark:bg-amber-950/40 text-amber-800 dark:text-amber-300 text-xs"
            title={`Path parameter: ${seg.name}`}
          >
            {`{${seg.name}}`}
          </span>
        ) : (
          <span class="text-zinc-700 dark:text-zinc-300">{seg.text}</span>
        )}
      </Fragment>
    ))}
  </code>
  {showTryIt ? (
    <button
      type="button"
      data-tangly-header-tryit
      class="ml-auto inline-flex items-center gap-1 px-3 py-1 text-xs font-medium rounded-md text-white shrink-0"
      style="background: var(--tangly-color-primary, #ea580c)"
      title="Try this endpoint"
    >
      Try it <span aria-hidden="true">→</span>
    </button>
  ) : null}
</div>

{showTryIt ? (
  <script is:inline>
    document.querySelectorAll("[data-tangly-header-tryit]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const root = btn.closest(".tangly-openapi-split") || document;
        const panel = root.querySelector("[data-tangly-api-panel]");
        if (!panel) return;
        panel.scrollIntoView({ behavior: "smooth", block: "start" });
        const form = panel.querySelector("[data-tangly-tryit]");
        const toggle = panel.querySelector("[data-tangly-tryit-toggle]");
        if (form && form.classList.contains("hidden") && toggle) toggle.click();
      });
    });
  </script>
) : null}

---
export interface Props {
  tip: string;
}

const { tip } = Astro.props as Props;
---
<span class="tangly-tooltip relative inline-flex items-center group cursor-help underline decoration-dotted decoration-zinc-400 underline-offset-2">
  <slot />
  <span
    role="tooltip"
    class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 whitespace-nowrap rounded-md bg-zinc-900 dark:bg-zinc-100 px-2 py-1 text-xs font-medium text-white dark:text-zinc-900 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-150 z-50 shadow-lg"
  >{tip}</span>
</span>

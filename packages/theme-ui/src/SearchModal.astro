---
import type { DocsJson } from "@tanglydocs/schema";

export interface Props {
  config: DocsJson;
}

const { config } = Astro.props as Props;
const placeholder = config.search?.prompt ?? "Search docs…";
---

<dialog
  id="tangly-search-modal"
  class="tangly-search-modal w-full max-w-2xl rounded-2xl bg-[var(--tangly-color-bg)] text-[var(--tangly-color-fg)] border border-[var(--tangly-color-border)] shadow-2xl backdrop:bg-black/40 p-0"
  aria-label="Search docs"
>
  <form id="tangly-search-form" class="flex flex-col" method="dialog">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-[var(--tangly-color-border)]">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--tangly-color-muted)]" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        id="tangly-search-input"
        type="search"
        autocomplete="off"
        placeholder={placeholder}
        class="flex-1 bg-transparent outline-none text-base text-[var(--tangly-color-fg)] placeholder:text-[var(--tangly-color-muted)]"
        aria-label="Search query"
      />
      <button
        type="button"
        id="tangly-search-close"
        class="text-xs text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] px-2 py-0.5 rounded border border-[var(--tangly-color-border)]"
        aria-label="Close"
      >
        Esc
      </button>
    </div>

    <ul
      id="tangly-search-results"
      class="max-h-[60vh] overflow-y-auto tangly-scroll p-2"
      role="listbox"
      aria-label="Results"
    >
      <li class="text-sm text-[var(--tangly-color-muted)] px-3 py-6 text-center">
        Type to search…
      </li>
    </ul>

    <div class="px-4 py-2 border-t border-[var(--tangly-color-border)] flex items-center gap-3 text-xs text-[var(--tangly-color-muted)]">
      <span><kbd class="px-1.5 py-0.5 border border-[var(--tangly-color-border)] rounded">↑↓</kbd> navigate</span>
      <span><kbd class="px-1.5 py-0.5 border border-[var(--tangly-color-border)] rounded">↵</kbd> open</span>
      <span><kbd class="px-1.5 py-0.5 border border-[var(--tangly-color-border)] rounded">esc</kbd> close</span>
    </div>
  </form>
</dialog>

<script>
  type PagefindResult = {
    id: string;
    data: () => Promise<{
      url: string;
      excerpt: string;
      meta: { title?: string; slug?: string };
    }>;
  };
  type Pagefind = {
    search: (q: string) => Promise<{ results: PagefindResult[] }>;
  };

  let pf: Pagefind | null = null;
  let pfLoadFailed = false;
  let activeIndex = 0;

  async function ensurePagefind(): Promise<Pagefind | null> {
    if (pf) return pf;
    if (pfLoadFailed) return null;
    try {
      // pagefind.js is a static asset emitted by `tangly build` into
      // <outDir>/pagefind/. It doesn't exist at SSG time, so we hide
      // the URL behind a runtime-built string so Vite/Rollup don't try
      // to bundle-resolve it during the static build.
      const href = ["", "pagefind", "pagefind.js"].join("/");
      pf = (await import(/* @vite-ignore */ href)) as Pagefind;
      return pf;
    } catch {
      pfLoadFailed = true;
      return null;
    }
  }

  function debounce<F extends (...args: unknown[]) => void>(fn: F, ms: number): F {
    let t: ReturnType<typeof setTimeout> | null = null;
    return ((...args: unknown[]) => {
      if (t) clearTimeout(t);
      t = setTimeout(() => fn(...args), ms);
    }) as F;
  }

  function escapeHtml(s: string): string {
    const map: Record<string, string> = {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    };
    return s.replace(/[&<>"']/g, (c) => map[c] ?? c);
  }

  function el(tag: string, props: Record<string, string> = {}, children: (Node | string)[] = []): HTMLElement {
    const node = document.createElement(tag);
    for (const [k, v] of Object.entries(props)) {
      if (k === "class") node.className = v;
      else node.setAttribute(k, v);
    }
    for (const c of children) node.appendChild(typeof c === "string" ? document.createTextNode(c) : c);
    return node;
  }

  const dialog = document.getElementById("tangly-search-modal") as HTMLDialogElement | null;
  const input = document.getElementById("tangly-search-input") as HTMLInputElement | null;
  const results = document.getElementById("tangly-search-results");
  const closeBtn = document.getElementById("tangly-search-close");

  function open() {
    if (!dialog) return;
    if (typeof dialog.showModal === "function") dialog.showModal();
    else dialog.setAttribute("open", "");
    if (input) {
      input.value = "";
      input.focus();
    }
    if (results) {
      while (results.firstChild) results.removeChild(results.firstChild);
      results.appendChild(
        el("li", { class: "text-sm text-[var(--tangly-color-muted)] px-3 py-6 text-center" }, ["Type to search…"]),
      );
    }
    activeIndex = 0;
  }

  function close() {
    dialog?.close();
  }

  document.addEventListener("tangly:open-search", open);
  closeBtn?.addEventListener("click", close);

  // Esc closes via dialog's native behavior; nothing extra needed.

  function setActive(idx: number) {
    if (!results) return;
    const items = results.querySelectorAll("li[data-result]");
    items.forEach((it, i) => {
      it.setAttribute("aria-selected", i === idx ? "true" : "false");
      (it as HTMLElement).style.background =
        i === idx ? "var(--tangly-color-bg-elevated)" : "transparent";
    });
    activeIndex = idx;
  }

  // Monotonically incrementing token to discard stale search responses.
  // Without this, a slow earlier query can resolve after a fast later one
  // and overwrite the visible results with stale content.
  let queryToken = 0;

  async function runQuery(q: string) {
    if (!results) return;
    const myToken = ++queryToken;
    while (results.firstChild) results.removeChild(results.firstChild);

    if (!q.trim()) {
      results.appendChild(
        el("li", { class: "text-sm text-[var(--tangly-color-muted)] px-3 py-6 text-center" }, ["Type to search…"]),
      );
      return;
    }

    const lib = await ensurePagefind();
    if (myToken !== queryToken) return;
    if (!lib) {
      results.appendChild(
        el("li", { class: "text-sm text-[var(--tangly-color-muted)] px-3 py-6 text-center" }, [
          "Search index unavailable. Run `tangly build` first.",
        ]),
      );
      return;
    }

    const { results: hits } = await lib.search(q);
    if (myToken !== queryToken) return;
    if (hits.length === 0) {
      results.appendChild(
        el("li", { class: "text-sm text-[var(--tangly-color-muted)] px-3 py-6 text-center" }, [
          `No matches for "${q}".`,
        ]),
      );
      return;
    }

    const top = hits.slice(0, 10);
    const datas = await Promise.all(top.map((h) => h.data()));
    if (myToken !== queryToken) return;
    datas.forEach((d, i) => {
      const li = el("li", {
        class: "rounded-md cursor-pointer",
        role: "option",
        "data-result": String(i),
        "data-url": d.meta.slug ? `${import.meta.env.BASE_URL}${d.meta.slug}` : d.url,
      });
      const a = el("a", {
        href: d.meta.slug ? `${import.meta.env.BASE_URL}${d.meta.slug}` : d.url,
        class: "block px-3 py-2 no-underline",
      });
      a.appendChild(el("div", { class: "font-medium text-sm text-[var(--tangly-color-fg)]" }, [
        d.meta.title ?? d.url,
      ]));
      // Excerpt is HTML with <mark> highlights; we sanitize then re-parse
      // the <mark> tags via a small whitelist.
      const excerpt = el("div", { class: "text-xs text-[var(--tangly-color-muted)] mt-0.5 line-clamp-2" });
      const safe = escapeHtml(d.excerpt).replace(/&lt;mark&gt;/g, "<mark>").replace(/&lt;\/mark&gt;/g, "</mark>");
      // Build a fragment from the sanitized markup. innerHTML here is safe
      // because escapeHtml ran first and the only allowed tag is <mark>.
      const range = document.createRange();
      range.selectNodeContents(excerpt);
      const frag = range.createContextualFragment(safe);
      excerpt.appendChild(frag);
      a.appendChild(excerpt);
      li.appendChild(a);
      li.addEventListener("mouseenter", () => setActive(i));
      results.appendChild(li);
    });
    setActive(0);
  }

  const debouncedRun = debounce((...args: unknown[]) => {
    void runQuery(args[0] as string);
  }, 80);
  input?.addEventListener("input", () => debouncedRun(input.value));

  document.addEventListener("keydown", (e) => {
    if (!dialog || !dialog.open) return;
    const items = results?.querySelectorAll("li[data-result]");
    if (!items || items.length === 0) return;
    if (e.key === "ArrowDown") {
      e.preventDefault();
      setActive(Math.min(activeIndex + 1, items.length - 1));
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      setActive(Math.max(activeIndex - 1, 0));
    } else if (e.key === "Enter") {
      e.preventDefault();
      const target = items[activeIndex] as HTMLElement | undefined;
      const url = target?.dataset.url;
      if (url) location.href = url;
    }
  });
</script>

<style>
  .tangly-search-modal {
    margin: auto;
  }
  .tangly-search-modal[open] {
    display: flex;
    flex-direction: column;
  }
  mark {
    background: color-mix(in oklab, var(--tangly-color-primary) 25%, transparent);
    color: inherit;
    padding: 0 0.1em;
    border-radius: 0.125rem;
  }
</style>

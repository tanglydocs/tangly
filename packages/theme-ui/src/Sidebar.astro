---
import type { DocsJson } from "@tanglydocs/schema";
import type { SidebarItem } from "@tanglydocs/tangly";
import Icon from "./components/Icon.astro";

export interface Props {
  items: SidebarItem[];
  currentSlug: string;
  config: DocsJson;
  /** Internal: recursion depth (controls left padding). */
  _depth?: number;
}

const { items, currentSlug, config, _depth = 0 } = Astro.props as Props;

const isRoot = _depth === 0;
---
{isRoot ? (
  <nav aria-label="Sidebar" class="text-sm">
    <ul class="space-y-0.5">
      {items.map((item) => (
        <li>
          {item.isGroup ? (
            <details open={item.expanded ?? true} class="group/det">
              <summary class="flex items-center gap-1.5 cursor-pointer list-none select-none text-xs font-semibold uppercase tracking-wide text-[var(--tangly-color-muted)] py-2 px-2">
                <span class="inline-flex transition-transform group-open/det:rotate-90">
                  <Icon icon="ChevronRight" size={12} />
                </span>
                {item.icon && <Icon icon={item.icon} size={14} />}
                <span class="flex-1">{item.title}</span>
                {item.tag && (
                  <span class="ml-1 text-[10px] font-medium uppercase tracking-wide rounded-full px-1.5 py-0.5 bg-[var(--tangly-color-bg-elevated)] text-[var(--tangly-color-muted)] border border-[var(--tangly-color-border)]">
                    {item.tag}
                  </span>
                )}
              </summary>
              <div class="mt-0.5 ml-1 pl-3 border-l border-[var(--tangly-color-border)]">
                <Astro.self items={item.children ?? []} currentSlug={currentSlug} config={config} _depth={_depth + 1} />
              </div>
            </details>
          ) : (
            <a
              href={`/${item.slug}`}
              data-active={item.slug === currentSlug ? "true" : "false"}
              class="tangly-side-link flex items-center gap-2 px-2 py-1.5 rounded-md text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] hover:bg-[var(--tangly-color-bg-elevated)] no-underline"
            >
              {item.icon ? <Icon icon={item.icon} size={14} /> : <span class="w-3.5 inline-block"></span>}
              <span class="flex-1 truncate">{item.title}</span>
              {item.tag && (
                <span class="text-[10px] font-medium uppercase tracking-wide rounded-full px-1.5 py-0.5 bg-[var(--tangly-color-bg-elevated)] text-[var(--tangly-color-muted)] border border-[var(--tangly-color-border)]">
                  {item.tag}
                </span>
              )}
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>
) : (
  <ul class="space-y-0.5">
    {items.map((item) => (
      <li>
        {item.isGroup ? (
          <details open={item.expanded ?? true} class="group/det">
            <summary class="flex items-center gap-1.5 cursor-pointer list-none select-none py-1.5 px-2 text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] rounded-md">
              <span class="inline-flex transition-transform group-open/det:rotate-90">
                <Icon icon="ChevronRight" size={12} />
              </span>
              {item.icon && <Icon icon={item.icon} size={14} />}
              <span class="flex-1">{item.title}</span>
              {item.tag && (
                <span class="ml-1 text-[10px] font-medium uppercase tracking-wide rounded-full px-1.5 py-0.5 bg-[var(--tangly-color-bg-elevated)] text-[var(--tangly-color-muted)] border border-[var(--tangly-color-border)]">
                  {item.tag}
                </span>
              )}
            </summary>
            <div class="mt-0.5 ml-1 pl-3 border-l border-[var(--tangly-color-border)]">
              <Astro.self items={item.children ?? []} currentSlug={currentSlug} config={config} _depth={_depth + 1} />
            </div>
          </details>
        ) : (
          <a
            href={`/${item.slug}`}
            data-active={item.slug === currentSlug ? "true" : "false"}
            class="tangly-side-link flex items-center gap-2 px-2 py-1.5 rounded-md text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] hover:bg-[var(--tangly-color-bg-elevated)] no-underline"
          >
            {item.icon ? <Icon icon={item.icon} size={14} /> : <span class="w-3.5 inline-block"></span>}
            <span class="flex-1 truncate">{item.title}</span>
            {item.tag && (
              <span class="text-[10px] font-medium uppercase tracking-wide rounded-full px-1.5 py-0.5 bg-[var(--tangly-color-bg-elevated)] text-[var(--tangly-color-muted)] border border-[var(--tangly-color-border)]">
                {item.tag}
              </span>
            )}
          </a>
        )}
      </li>
    ))}
  </ul>
)}

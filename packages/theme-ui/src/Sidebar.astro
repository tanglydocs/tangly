---
import type { DocsJson } from "@tanglydocs/schema";
import type { SidebarItem } from "tangly";
import Icon from "./components/Icon.astro";

export interface Props {
  items: SidebarItem[];
  currentSlug: string;
  config: DocsJson;
  /** Internal: recursion depth (controls left padding). */
  _depth?: number;
}

const { items, currentSlug, config, _depth = 0 } = Astro.props as Props;

const isRoot = _depth === 0;
---
{isRoot ? (
  <nav aria-label="Sidebar" class="text-[14px]">
    <ul class="space-y-6">
      {items.map((item) => (
        <li>
          {item.isGroup ? (
            <div>
              <div class="px-2 pt-1 pb-2 text-[13px] font-semibold text-[var(--tangly-color-fg)]">
                {item.title}
              </div>
              <ul class="space-y-0.5">
                <Astro.self items={item.children ?? []} currentSlug={currentSlug} config={config} _depth={_depth + 1} />
              </ul>
            </div>
          ) : (
            <a
              href={`${import.meta.env.BASE_URL}${item.slug}`}
              data-active={item.slug === currentSlug ? "true" : "false"}
              class="tangly-side-link flex items-center gap-2.5 px-2 py-2 rounded-md text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] hover:bg-[var(--tangly-color-bg-elevated)] no-underline"
            >
              {item.icon ? <Icon icon={item.icon} size={15} /> : null}
              <span class="flex-1 truncate">{item.title}</span>
              {item.tag && (
                item.methodColor ? (
                  <span
                    class="shrink-0 text-[9px] font-mono font-bold uppercase tracking-wide px-1 py-0.5 rounded-md leading-none"
                    style={`color:${item.methodColor};background:${item.methodColor}1a`}
                  >
                    {item.tag}
                  </span>
                ) : (
                  <span class="text-[10px] font-medium uppercase tracking-wide text-[var(--tangly-color-muted)]">
                    {item.tag}
                  </span>
                )
              )}
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>
) : (
  <>
    {items.map((item) => (
      <li>
        {item.isGroup ? (
          <div class="pt-4">
            <div class="px-2 pb-1 text-[12px] font-semibold text-[var(--tangly-color-fg)]">
              {item.title}
            </div>
            <ul class="space-y-0.5">
              <Astro.self items={item.children ?? []} currentSlug={currentSlug} config={config} _depth={_depth + 1} />
            </ul>
          </div>
        ) : (
          <a
            href={`${import.meta.env.BASE_URL}${item.slug}`}
            data-active={item.slug === currentSlug ? "true" : "false"}
            class="tangly-side-link flex items-center gap-2.5 px-2 py-2 rounded-md text-[var(--tangly-color-muted)] hover:text-[var(--tangly-color-fg)] hover:bg-[var(--tangly-color-bg-elevated)] no-underline"
          >
            {item.icon ? <Icon icon={item.icon} size={15} /> : null}
            <span class="flex-1 truncate">{item.title}</span>
            {item.tag && (
              item.methodColor ? (
                <span
                  class="shrink-0 text-[9px] font-mono font-bold uppercase tracking-wide px-1 py-0.5 rounded-md leading-none"
                  style={`color:${item.methodColor};background:${item.methodColor}1a`}
                >
                  {item.tag}
                </span>
              ) : (
                <span class="text-[10px] font-medium uppercase tracking-wide text-[var(--tangly-color-muted)]">
                  {item.tag}
                </span>
              )
            )}
          </a>
        )}
      </li>
    ))}
  </>
)}

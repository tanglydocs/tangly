{
  "name": "@tangly/schema",
  "version": "0.0.1",
  "description": "docs.json Zod schema + JSON Schema for Tangly.",
  "keywords": [
    "docs",
    "mintlify",
    "schema",
    "zod"
  ],
  "homepage": "https://github.com/nikcub/tangly",
  "bugs": "https://github.com/nikcub/tangly/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikcub/tangly.git",
    "directory": "packages/schema"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./docs.json": "./dist/docs.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo --build",
    "dev": "tsgo --build --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  }
}

{
  "name": "@tanglydocs/theme-pip",
  "version": "0.0.11",
  "description": "Minimal Tangly theme. Single-column, topbar-only chrome — for tiny docs sites (4–5 pages). UI shell comes from @tanglydocs/theme-ui.",
  "keywords": [
    "docs",
    "tangly",
    "theme"
  ],
  "homepage": "https://github.com/tanglydocs/tangly",
  "bugs": "https://github.com/tanglydocs/tangly/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanglydocs/tangly.git",
    "directory": "packages/theme-pip"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./*": "./src/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo --build",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tanglydocs/theme-ui": "workspace:*",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}

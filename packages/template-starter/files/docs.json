{
  "$schema": "https://tangly.dev/schema/docs.json",
  "name": "{{name}}",
  "theme": "tang",
  "favicon": "/images/favicon.ico",
  "logo": {
    "light": "/images/logo.png",
    "dark": "/images/logo-dark.png",
    "href": "/"
  },
  "colors": {
    "primary": "#D97706",
    "light": "#F59E0B",
    "dark": "#B45309"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["introduction", "getting-started"]
      },
      {
        "group": "Development",
        "pages": ["development/dev-server", "development/settings", "development/openapi"]
      },
      {
        "group": "Content",
        "pages": ["content/markdown", "content/navigation", "content/themes", "content/blocks"]
      }
    ]
  }
}

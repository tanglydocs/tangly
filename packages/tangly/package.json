{
  "name": "tangly",
  "version": "0.0.3",
  "description": "Self-hosted, open-source documentation framework. Drop-in compatible with Mintlify projects — render existing docs.json/MDX corpora unmodified, with Astro under the hood. Includes a CLI (init, dev, build, migrate), pluggable themes, and full MDX component parity.",
  "keywords": [
    "astro",
    "content",
    "docs",
    "docs-as-code",
    "documentation",
    "mdx",
    "mintlify",
    "openapi",
    "site-generator",
    "ssg",
    "static-site"
  ],
  "homepage": "https://github.com/tanglydocs/tangly",
  "bugs": "https://github.com/tanglydocs/tangly/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanglydocs/tangly.git",
    "directory": "packages/tangly"
  },
  "bin": {
    "tangly": "./bin/tangly.js"
  },
  "files": [
    "bin",
    "dist",
    "runtime/src",
    "runtime/astro.config.mjs",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo --build",
    "dev": "tsgo --build --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.2",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/node": "^10.0.6",
    "@astrojs/vercel": "^10.0.6",
    "@clack/prompts": "^1.2.0",
    "@shikijs/rehype": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "@shikijs/twoslash": "^4.0.2",
    "@tailwindcss/vite": "^4.2.4",
    "@tanglydocs/schema": "0.0.2",
    "@tanglydocs/theme-geist": "0.0.2",
    "@tanglydocs/theme-pip": "0.0.2",
    "@tanglydocs/theme-pith": "0.0.2",
    "@tanglydocs/theme-readable": "0.0.2",
    "@tanglydocs/theme-tang": "0.0.2",
    "@tanglydocs/theme-ui": "0.0.2",
    "astro": "^6.1.10",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "pagefind": "^1.5.2",
    "picocolors": "^1.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-shiki": "^0.0.9",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.4",
    "twoslash": "^0.3.8",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "src/astro/template/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "references": [{ "path": "../schema" }]
}

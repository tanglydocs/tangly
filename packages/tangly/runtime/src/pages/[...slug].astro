---
import { getCollection, render } from "astro:content";
import { manifest } from "virtual:tangly/manifest";
import Layout from "@tanglydocs/theme-ui/Layout.astro";
import OpenApiEndpoint from "@tanglydocs/theme-ui/components/OpenApiEndpoint.astro";
import OpenApiRedoc from "@tanglydocs/theme-ui/components/OpenApiRedoc.astro";
import OpenApiScalar from "@tanglydocs/theme-ui/components/OpenApiScalar.astro";
import OpenApiStoplight from "@tanglydocs/theme-ui/components/OpenApiStoplight.astro";
import PageShell from "@tanglydocs/theme-ui/PageShell.astro";
import type { PageEntry } from "tangly";
import { mdxComponents } from "../lib/mdx-components.ts";

// Eagerly discover user templates so we can dispatch to them per page.
// `@user-template/*` is aliased by the integration to <userRoot>/templates.
const userTemplates = import.meta.glob<unknown>(
  "/@user-template/*.{astro,tsx,jsx}",
  { eager: true },
);

function findTemplate(name: string | undefined): unknown | null {
  if (!name) return null;
  const stem = name.replace(/\.(astro|tsx?|jsx?)$/i, "");
  for (const [path, mod] of Object.entries(userTemplates)) {
    const file = path.split("/").pop() ?? "";
    const fileStem = file.replace(/\.[^.]+$/, "");
    if (fileStem === stem) {
      return (mod as { default?: unknown }).default ?? mod;
    }
  }
  return null;
}

export async function getStaticPaths() {
  const excluded = new Set<string>(manifest.excludedSlugs ?? []);
  const entries = await getCollection("docs");
  const entrySlugs = new Set(entries.map((e) => e.id));

  const mdxPaths = entries
    .filter((entry) => !excluded.has(entry.id))
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry, synthPage: null as null | (typeof manifest.pages)[number][1] },
    }));

  // Synthesized OpenAPI pages have no MDX entry — emit a path per
  // manifest page that isn't already covered by the docs collection.
  const synthPaths = manifest.pages
    .filter(([slug]) => !entrySlugs.has(slug) && !excluded.has(slug))
    .map(([slug, page]) => ({
      params: { slug },
      props: { entry: null, synthPage: page },
    }));

  return [...mdxPaths, ...synthPaths];
}

const { entry, synthPage } = Astro.props;
const { Content } = entry
  ? await render(entry)
  : ({ Content: null } as { Content: null });

const pageMeta = manifest.pages.find(([s]) => s === (entry?.id ?? synthPage?.slug));

const slugForPage = entry?.id ?? synthPage?.slug ?? "";

const orphan: PageEntry = {
  slug: slugForPage,
  file: "",
  frontmatter: {
    title: entry?.data?.title ?? synthPage?.frontmatter?.title ?? slugForPage,
    description: entry?.data?.description ?? synthPage?.frontmatter?.description,
  },
  breadcrumbs: [],
  sidebar: manifest.navigation.rootSidebar,
  draft: false,
};

const basePage: PageEntry = (pageMeta?.[1] as PageEntry) ?? synthPage ?? orphan;
// Auto-promote OpenAPI / API frontmatter pages into split-layout mode unless
// the author explicitly picked another mode (custom/wide/center/default).
const fmModeRaw = (entry?.data?.mode ?? basePage.frontmatter.mode) as string | undefined;
const hasOpenapi = Boolean(
  entry?.data?.openapi ?? basePage.frontmatter.openapi ?? entry?.data?.api ?? basePage.frontmatter.api,
);
const page: PageEntry =
  hasOpenapi && !fmModeRaw
    ? {
        ...basePage,
        frontmatter: { ...basePage.frontmatter, mode: "api" },
      }
    : basePage;

// Auto-derive title from openapi op.summary if no explicit title.
let derivedTitle: string | undefined;
let derivedDesc: string | undefined;

// Detect openapi frontmatter:
//   `openapi: METHOD path` → pure auto-generated endpoint
//   `api: METHOD path`     → companion-MDX (narrative renders above endpoint)
const apiCompanionAttr = (entry?.data?.api ?? page.frontmatter.api) as string | undefined;
const openapiAttr = (entry?.data?.openapi ??
  page.frontmatter.openapi ??
  apiCompanionAttr) as string | undefined;
const isCompanion = Boolean(apiCompanionAttr) && !page.frontmatter.openapi && !entry?.data?.openapi;
let openapi: { method: string; path: string; spec: string } | undefined;
let fallbackResponseSchema: Record<string, unknown> | undefined;
if (openapiAttr) {
  const parts = openapiAttr.trim().split(/\s+/);
  if (parts.length >= 2) {
    const [method, ...rest] = parts;
    const path = rest.join(" ");
    const apiCfg = manifest.config.api;
    // Resolve spec URL: prefer the owning tab's openapi (covers
    // tab-specific specs), then fall back to top-level api.openapi.
    const tabOpenapi = manifest.navigation.tabs.find(
      (t) => t.slug === page.tab?.slug,
    )?.openapi;
    const spec = tabOpenapi
      ?? (typeof apiCfg?.openapi === "string"
        ? apiCfg.openapi
        : Array.isArray(apiCfg?.openapi)
          ? apiCfg.openapi[0]
          : undefined);
    if (spec) {
      openapi = { method: method!.toLowerCase(), path, spec };
      // Best-effort SSR fetch: title/description for the page header,
      // plus a JSON-pointer lookup for `api.responseFallback` so we
      // can synthesize an example body for empty 200 schemas.
      try {
        const specUrl = spec.startsWith("http") ? spec : `https://${spec}`;
        const res = await fetch(specUrl, { redirect: "follow" });
        if (res.ok) {
          const doc = (await res.json()) as Record<string, unknown>;
          const paths = doc.paths as
            | Record<string, Record<string, { summary?: string; description?: string }>>
            | undefined;
          const op = paths?.[path]?.[method!.toLowerCase()];
          derivedTitle = op?.summary;
          derivedDesc = op?.description;

          const ptr = (apiCfg as { responseFallback?: string } | undefined)?.responseFallback;
          if (ptr && ptr.startsWith("#/")) {
            const segments = ptr.slice(2).split("/").map((p) => p.replace(/~1/g, "/").replace(/~0/g, "~"));
            let cur: unknown = doc;
            for (const segment of segments) {
              if (cur === null || typeof cur !== "object") { cur = undefined; break; }
              cur = (cur as Record<string, unknown>)[segment];
            }
            if (cur && typeof cur === "object") {
              fallbackResponseSchema = cur as Record<string, unknown>;
            }
          }
        }
      } catch {
        // ignore — endpoint will still render via OpenApiEndpoint
      }
    }
  }
}

const fmTitle =
  page.frontmatter.title ??
  entry?.data?.title ??
  derivedTitle ??
  humanizeSlug(slugForPage);
const fmDesc = page.frontmatter.description ?? entry?.data?.description ?? derivedDesc;

// Surface the resolved title/description back into the page so PageShell
// renders the correct H1 + subtitle even when frontmatter is sparse.
const renderedPage: PageEntry = {
  ...page,
  frontmatter: {
    ...page.frontmatter,
    title: fmTitle,
    description: fmDesc,
  },
};

// Dispatch to a user template if frontmatter (or inherited section
// defaults) names one.
const templateName = page.frontmatter.template;
const Template = findTemplate(templateName) as
  | ((p: Record<string, unknown>) => unknown)
  | null;
if (templateName && !Template) {
  console.warn(
    `[tangly] template "${templateName}" not found in ./templates — falling back to default.`,
  );
}

function humanizeSlug(slug: string): string {
  const last = slug.split("/").pop() ?? slug;
  return last
    .replace(/[-_]/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}
---

{Template ? (
  <Template
    config={manifest.config}
    page={renderedPage}
    navigation={manifest.navigation}
    frontmatter={renderedPage.frontmatter}
    manifest={manifest}
  >
    {Content ? <Content components={mdxComponents} /> : null}
  </Template>
) : (
  <Layout
    config={manifest.config}
    page={renderedPage}
    navigation={manifest.navigation}
    pageTitle={fmTitle}
    pageDescription={fmDesc}
  >
    <PageShell page={renderedPage} config={manifest.config}>
      {/* Order: companion-MDX puts narrative ABOVE the endpoint render;
          pure `openapi:` frontmatter renders the endpoint above (no MDX). */}
      {isCompanion && Content ? <Content components={mdxComponents} /> : null}
      {openapi ? (
        (() => {
          const viewer = (manifest.config.api as { viewer?: string } | undefined)?.viewer ?? "tangly";
          const apiCfg = manifest.config.api as
            | {
                baseUrl?: string | string[];
                auth?: { method?: string; name?: string };
                playground?: { mode?: "interactive" | "simple" | "hide"; credentials?: boolean };
                codeSamples?: {
                  languages?: string[];
                  prefill?: boolean;
                  defaults?: "required" | "all";
                  autogenerate?: boolean;
                };
                params?: { expanded?: "all" | "closed"; post?: string[] };
                url?: "full";
                responseFallback?: string;
              }
            | undefined;
          const baseUrl = typeof apiCfg?.baseUrl === "string"
            ? apiCfg.baseUrl
            : Array.isArray(apiCfg?.baseUrl)
              ? apiCfg.baseUrl[0]
              : undefined;
          // Frontmatter overrides docs.json for auth + playground.
          const fmAuthMethod = (entry?.data?.authMethod ?? page.frontmatter.authMethod) as
            | "bearer" | "basic" | "key" | "none" | undefined;
          const fmPlayground = (entry?.data?.playground ?? page.frontmatter.playground) as
            | "interactive" | "simple" | "none" | undefined;
          const authMethod = (fmAuthMethod ?? apiCfg?.auth?.method) as
            | "bearer" | "basic" | "key" | "cookie" | "none" | undefined;
          const authName = apiCfg?.auth?.name;
          const playgroundMode = fmPlayground === "none"
            ? "hide"
            : (fmPlayground ?? apiCfg?.playground?.mode ?? "interactive");
          const languages = apiCfg?.codeSamples?.languages ?? ["curl", "typescript", "python"];
          if (viewer === "scalar") {
            return <OpenApiScalar spec={openapi.spec} method={openapi.method} path={openapi.path} />;
          }
          if (viewer === "redoc") {
            return <OpenApiRedoc spec={openapi.spec} method={openapi.method} path={openapi.path} />;
          }
          if (viewer === "stoplight") {
            return <OpenApiStoplight spec={openapi.spec} method={openapi.method} path={openapi.path} />;
          }
          // `cookie` was historically accepted in api.auth.method but the
          // OpenApiEndpoint only supports bearer/basic/key/none — narrow.
          const safeAuthMethod = authMethod === "cookie" ? "none" : authMethod;
          return (
            <OpenApiEndpoint
              spec={openapi.spec}
              method={openapi.method}
              path={openapi.path}
              layout="split"
              languages={languages}
              playgroundMode={playgroundMode}
              {...(baseUrl ? { baseUrl } : {})}
              {...(safeAuthMethod ? { authMethod: safeAuthMethod } : {})}
              {...(authName ? { authName } : {})}
              {...(apiCfg?.playground?.credentials !== undefined && { credentials: apiCfg.playground.credentials })}
              {...(apiCfg?.codeSamples?.prefill !== undefined && { prefill: apiCfg.codeSamples.prefill })}
              {...(apiCfg?.codeSamples?.defaults && { defaults: apiCfg.codeSamples.defaults })}
              {...(apiCfg?.params?.post && { paramsPost: apiCfg.params.post })}
              {...(apiCfg?.url === "full" && { showFullUrl: true })}
              {...(fallbackResponseSchema && { fallbackResponseSchema })}
            />
          );
        })()
      ) : null}
      {!isCompanion && Content ? <Content components={mdxComponents} /> : null}
    </PageShell>
  </Layout>
)}

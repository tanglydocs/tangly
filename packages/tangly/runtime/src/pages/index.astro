---
import { getCollection, render } from "astro:content";
import { manifest } from "virtual:tangly/manifest";
import Layout from "@tanglydocs/theme-ui/Layout.astro";
import PageShell from "@tanglydocs/theme-ui/PageShell.astro";
import type { PageEntry } from "tangly";
import HomeSplash from "../components/HomeSplash.astro";
import { mdxComponents } from "../lib/mdx-components.ts";

export const prerender = true;

const entries = await getCollection("docs");

// Mintlify parity: a root `index` page (index.mdx / index.md) is the site
// home and renders at `/`. Astro's glob loader ids it as "index" (only a
// nested `foo/index.mdx` collapses to `foo`). When that page exists we render
// it in full at `/`; otherwise we fall back to <HomeSplash>, which redirects
// to the first navigable page.
const homeEntry = entries.find((e) => e.id === "index" || e.id === "");

function humanizeSlug(slug: string): string {
  const last = slug.split("/").pop() ?? slug;
  return last.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
}

let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
let homePage: PageEntry | null = null;
let homeTitle = "";
let homeDesc: string | undefined;
if (homeEntry) {
  ({ Content } = await render(homeEntry));
  const pageMeta = manifest.pages.find(([s]) => s === homeEntry.id);
  const basePage: PageEntry = (pageMeta?.[1] as PageEntry) ?? {
    slug: homeEntry.id,
    file: "",
    frontmatter: {},
    breadcrumbs: [],
    sidebar: manifest.navigation.rootSidebar,
    draft: false,
  };
  homeTitle =
    homeEntry.data?.title ?? basePage.frontmatter.title ?? humanizeSlug(homeEntry.id || "index");
  homeDesc = homeEntry.data?.description ?? basePage.frontmatter.description;
  // The home page is typically an orphan (index.mdx is rarely listed in nav),
  // so its own sidebar is empty. Mintlify shows the first tab's nav on `/`, so
  // fall back to the first tab's sidebar (then rootSidebar) to match.
  const firstTab = manifest.navigation.tabs[0];
  const homeSidebar =
    basePage.sidebar.length > 0
      ? basePage.sidebar
      : (firstTab?.sidebar ?? manifest.navigation.rootSidebar);
  homePage = {
    ...basePage,
    sidebar: homeSidebar,
    frontmatter: { ...basePage.frontmatter, title: homeTitle, description: homeDesc },
  };
}
---

{
  homePage ? (
    <Layout
      config={manifest.config}
      page={homePage}
      navigation={manifest.navigation}
      pageTitle={homeTitle}
      pageDescription={homeDesc}
    >
      <PageShell page={homePage} config={manifest.config}>
        {Content ? <Content components={mdxComponents} /> : null}
      </PageShell>
    </Layout>
  ) : (
    <HomeSplash />
  )
}

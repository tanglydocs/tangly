---
import Icon from "./Icon.astro";

export interface Props {
  icon: string;
  classes: string;
  iconClass: string;
  label?: string;
}

const { icon, classes, iconClass, label } = Astro.props as Props;
---
<aside
  role="note"
  aria-label={label}
  class={`tangly-callout my-4 flex items-start gap-3 rounded-lg border-l-4 px-4 py-3 ${classes}`}
>
  <span class={`shrink-0 mt-0.5 ${iconClass}`}>
    <Icon icon={icon} size={18} />
  </span>
  <div class="flex-1 min-w-0 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0 leading-relaxed">
    <slot />
  </div>
</aside>

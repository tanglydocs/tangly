---
export interface Props {}

const groupId = `tabs-${Math.random().toString(36).slice(2, 9)}`;
---
<div class="tangly-tabs my-6" data-tabs={groupId}>
  <div class="tangly-tabs-strip flex items-center gap-1 border-b border-zinc-200 dark:border-zinc-800 mb-4 overflow-x-auto" role="tablist"></div>
  <div class="tangly-tabs-panels"><slot /></div>
</div>
<script is:inline define:vars={{ groupId }}>
  (function () {
    const root = document.querySelector(`[data-tabs="${groupId}"]`);
    if (!root) return;
    const strip = root.querySelector(".tangly-tabs-strip");
    const panelsContainer = root.querySelector(".tangly-tabs-panels");
    if (!strip || !panelsContainer) return;
    const panels = Array.from(panelsContainer.querySelectorAll(":scope > .tangly-tab-panel"));
    panels.forEach((panel, i) => {
      const title = panel.getAttribute("data-tab-title") || `Tab ${i + 1}`;
      const btn = document.createElement("button");
      btn.type = "button";
      btn.setAttribute("role", "tab");
      btn.textContent = title;
      btn.className =
        "px-4 py-2 -mb-px text-sm font-medium border-b-2 border-transparent text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors whitespace-nowrap";
      btn.addEventListener("click", () => activate(i));
      strip.appendChild(btn);
      if (i !== 0) panel.style.display = "none";
    });
    function activate(idx) {
      Array.from(strip.children).forEach((b, i) => {
        const btn = b;
        if (i === idx) {
          btn.classList.add("border-zinc-900", "dark:border-zinc-100", "text-zinc-900", "dark:text-zinc-100");
          btn.classList.remove("border-transparent");
        } else {
          btn.classList.remove("border-zinc-900", "dark:border-zinc-100", "text-zinc-900", "dark:text-zinc-100");
          btn.classList.add("border-transparent");
        }
      });
      panels.forEach((p, i) => {
        p.style.display = i === idx ? "" : "none";
      });
    }
    activate(0);
  })();
</script>

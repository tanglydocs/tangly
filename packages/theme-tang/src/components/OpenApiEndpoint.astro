---
import { resolveMethodColor } from "./_openapi.ts";

/**
 * Renders a single OpenAPI endpoint with summary, parameters, responses,
 * and a try-it-out form.
 */
export interface Props {
  spec: string;
  method: string;
  path: string;
  baseUrl?: string;
  /** auth.method from docs.json `api.auth` */
  authMethod?: "bearer" | "basic" | "key" | "cookie" | "none";
  /** auth.name (header/cookie name when method=key/cookie) */
  authName?: string;
}

const { spec, method, path, baseUrl, authMethod, authName } = Astro.props as Props;
const methodLower = method.toLowerCase();
const methodColor = resolveMethodColor(methodLower);

interface OpenApiOp {
  summary?: string;
  description?: string;
  parameters?: Array<{
    name: string;
    in?: string;
    description?: string;
    required?: boolean;
    schema?: { type?: string };
  }>;
  responses?: Record<string, { description?: string }>;
  requestBody?: {
    description?: string;
    required?: boolean;
    content?: Record<string, { schema?: unknown }>;
  };
}

let op: OpenApiOp | null = null;
let loadError: string | null = null;
let resolvedServers: string[] = [];

try {
  const url = spec.startsWith("http") ? spec : `https://${spec}`;
  const res = await fetch(url, { redirect: "follow" });
  if (!res.ok) {
    loadError = `${res.status} ${res.statusText}`;
  } else {
    const doc = (await res.json()) as {
      paths?: Record<string, Record<string, OpenApiOp>>;
      servers?: Array<{ url?: string }>;
    };
    op = doc.paths?.[path]?.[methodLower] ?? null;
    if (!op) loadError = `No operation found for ${methodLower.toUpperCase()} ${path}`;
    resolvedServers = (doc.servers ?? [])
      .map((s) => s.url ?? "")
      .filter((u): u is string => u.length > 0);
  }
} catch (err) {
  loadError = `Failed to fetch ${spec}: ${(err as Error).message}`;
}

// baseUrl prop wins; otherwise first server in the spec; otherwise empty.
const effectiveBaseUrl = baseUrl ?? resolvedServers[0] ?? "";
const formId = `tangly-openapi-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="tangly-openapi-embed my-6">
  <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
    <div class="px-4 py-3 bg-zinc-50 dark:bg-zinc-900 border-b border-zinc-200 dark:border-zinc-800 flex items-center gap-3">
      <span
        class="inline-flex items-center justify-center px-2 py-0.5 rounded text-xs font-mono font-semibold uppercase text-white"
        style={`background:${methodColor}`}
      >
        {method.toUpperCase()}
      </span>
      <code class="text-sm font-mono text-zinc-800 dark:text-zinc-200">{path}</code>
    </div>

    <div class="p-4 space-y-4">
      {loadError ? (
        <p class="text-sm text-rose-500">{loadError}</p>
      ) : op ? (
        <>
          {op.summary ? <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">{op.summary}</h3> : null}
          {op.description ? <p class="text-sm text-zinc-700 dark:text-zinc-300">{op.description}</p> : null}

          {Array.isArray(op.parameters) && op.parameters.length > 0 ? (
            <div>
              <h4 class="font-semibold text-sm text-zinc-900 dark:text-zinc-100 mb-2">Parameters</h4>
              <ul class="space-y-2 text-sm">
                {op.parameters.map((p) => (
                  <li class="flex flex-col gap-0.5">
                    <div class="flex items-center gap-2 flex-wrap">
                      <code class="font-mono text-zinc-800 dark:text-zinc-200">{p.name}</code>
                      {p.in ? <span class="text-xs text-zinc-500">({p.in})</span> : null}
                      {p.required ? <span class="text-xs text-rose-500">required</span> : null}
                      {p.schema?.type ? <span class="text-xs text-zinc-500">· {p.schema.type}</span> : null}
                    </div>
                    {p.description ? (
                      <p class="text-zinc-600 dark:text-zinc-400 text-xs">{p.description}</p>
                    ) : null}
                  </li>
                ))}
              </ul>
            </div>
          ) : null}

          {op.responses && Object.keys(op.responses).length > 0 ? (
            <div>
              <h4 class="font-semibold text-sm text-zinc-900 dark:text-zinc-100 mb-2">Responses</h4>
              <ul class="space-y-1 text-sm">
                {Object.entries(op.responses).map(([code, info]) => (
                  <li>
                    <code class="font-mono mr-2">{code}</code>
                    {info.description}
                  </li>
                ))}
              </ul>
            </div>
          ) : null}

          {/* Try-it-out */}
          <details class="mt-2">
            <summary class="cursor-pointer text-sm font-semibold text-[var(--tangly-color-primary)] select-none">
              Try it
            </summary>
            <form
              id={formId}
              class="mt-3 space-y-3 text-sm"
              data-tangly-tryit
              data-method={methodLower}
              data-path={path}
              data-base-url={effectiveBaseUrl}
              data-auth-method={authMethod ?? "none"}
              data-auth-name={authName ?? ""}
            >
              <label class="flex flex-col gap-1">
                <span class="text-xs text-zinc-500">Base URL</span>
                <input
                  name="__baseUrl"
                  value={effectiveBaseUrl}
                  class="px-2 py-1.5 rounded border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 font-mono text-xs"
                  placeholder="https://api.example.com"
                />
              </label>

              {authMethod && authMethod !== "none" ? (
                <label class="flex flex-col gap-1">
                  <span class="text-xs text-zinc-500">
                    {authMethod === "bearer" ? "Bearer token" :
                     authMethod === "basic" ? "Basic auth (user:pass)" :
                     authMethod === "key" ? `API key (${authName ?? "X-API-Key"})` :
                     "Cookie value"}
                  </span>
                  <input
                    type="password"
                    name="__auth"
                    class="px-2 py-1.5 rounded border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 font-mono text-xs"
                    placeholder="•••"
                  />
                </label>
              ) : null}

              {Array.isArray(op.parameters) && op.parameters.length > 0 ? (
                <fieldset class="border border-zinc-200 dark:border-zinc-800 rounded p-2 space-y-2">
                  <legend class="px-1 text-xs text-zinc-500">Parameters</legend>
                  {op.parameters.map((p) => (
                    <label class="flex flex-col gap-0.5">
                      <span class="text-xs">
                        <code class="font-mono">{p.name}</code>
                        <span class="text-zinc-500"> · {p.in ?? "query"}</span>
                        {p.required ? <span class="text-rose-500"> required</span> : null}
                      </span>
                      <input
                        name={p.name}
                        data-in={p.in ?? "query"}
                        data-required={p.required ? "true" : "false"}
                        class="px-2 py-1 rounded border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 font-mono text-xs"
                      />
                    </label>
                  ))}
                </fieldset>
              ) : null}

              <button
                type="submit"
                class="inline-flex items-center px-3 py-1.5 rounded-md text-sm font-medium text-white"
                style="background: var(--tangly-color-primary)"
              >
                Send
              </button>

              <pre
                data-tangly-tryit-result
                class="hidden mt-2 max-h-80 overflow-auto p-2 rounded bg-zinc-950 text-zinc-100 text-xs"
              ></pre>
            </form>
          </details>
        </>
      ) : (
        <p class="text-sm text-zinc-500">No data for this endpoint.</p>
      )}
    </div>
  </div>
</div>

<script is:inline>
  document.querySelectorAll("[data-tangly-tryit]").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.currentTarget;
      const out = f.querySelector("[data-tangly-tryit-result]");
      const method = f.dataset.method;
      let path = f.dataset.path;
      const base = f.querySelector("input[name='__baseUrl']").value || "";
      const authMethod = f.dataset.authMethod;
      const authName = f.dataset.authName;
      const authValue = f.querySelector("input[name='__auth']")?.value ?? "";

      const headers = { Accept: "application/json" };
      const queryParams = new URLSearchParams();

      f.querySelectorAll("input[data-in]").forEach((input) => {
        const where = input.dataset.in;
        const name = input.name;
        const value = input.value;
        if (!value) return;
        if (where === "path") {
          path = path.replace(`{${name}}`, encodeURIComponent(value));
        } else if (where === "query") {
          queryParams.set(name, value);
        } else if (where === "header") {
          headers[name] = value;
        }
      });

      if (authMethod === "bearer" && authValue) {
        headers.Authorization = `Bearer ${authValue}`;
      } else if (authMethod === "basic" && authValue) {
        headers.Authorization = `Basic ${btoa(authValue)}`;
      } else if (authMethod === "key" && authValue) {
        headers[authName || "X-API-Key"] = authValue;
      } else if (authMethod === "cookie" && authValue) {
        headers.Cookie = `${authName || "session"}=${authValue}`;
      }

      const qs = queryParams.toString();
      const url = `${base.replace(/\/+$/, "")}${path}${qs ? "?" + qs : ""}`;

      out.classList.remove("hidden");
      out.textContent = `→ ${method.toUpperCase()} ${url}\n\nLoading…`;

      try {
        const res = await fetch(url, { method: method.toUpperCase(), headers, mode: "cors" });
        const text = await res.text();
        let pretty = text;
        try { pretty = JSON.stringify(JSON.parse(text), null, 2); } catch {}
        out.textContent = `← ${res.status} ${res.statusText}\n\n${pretty}`;
      } catch (err) {
        out.textContent = `✗ ${err.message}\n\n(Note: CORS may block direct browser calls; configure server-side proxy for production.)`;
      }
    });
  });
</script>

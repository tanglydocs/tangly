---
export interface Props {
  caption?: string;
}

const { caption } = Astro.props as Props;
---
<figure class="tangly-frame my-6 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 p-3 overflow-hidden">
  <div class="rounded-lg overflow-hidden flex items-center justify-center [&>img]:max-w-full [&>img]:h-auto [&>img]:rounded-lg">
    <slot />
  </div>
  {caption && (
    <figcaption class="mt-3 text-center text-sm text-zinc-500 dark:text-zinc-400">{caption}</figcaption>
  )}
</figure>

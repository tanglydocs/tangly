{
  "name": "@tangly/theme-tang",
  "version": "0.0.1",
  "private": true,
  "description": "Default theme for Tangly. Mintlify-Mint-inspired, but cleaner.",
  "keywords": [
    "docs",
    "tangly",
    "theme"
  ],
  "homepage": "https://github.com/tanglydocs/tangly",
  "bugs": "https://github.com/tanglydocs/tangly/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanglydocs/tangly.git",
    "directory": "packages/theme-tang"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./src/*"
  },
  "scripts": {
    "build": "tsgo --build",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests"
  }
}

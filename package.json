{
  "name": "tangly-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted, OSS docs framework that renders Mintlify projects unmodified.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "build": "bun run --filter '*' build",
    "ci": "bun run format:check && bun run lint && bun run build && bun run typecheck && bun run test",
    "dev:docs": "cd docs && ../packages/tangly/bin/tangly.js dev --no-open --port 4322",
    "build:docs": "cd docs && ../packages/tangly/bin/tangly.js build --out ./dist",
    "dev:opennem": "cd examples/opennem && ../../packages/tangly/bin/tangly.js dev --no-open --port 4321",
    "changeset": "changeset",
    "version": "changeset version && bun run scripts/sync-skill-versions.ts",
    "release": "bun run build && changeset publish"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5.7.0",
    "vitest": "^4"
  },
  "overrides": {
    "vite": "^7.3.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.2.0"
}

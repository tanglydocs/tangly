{
  "name": "tangly-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted, OSS docs framework that renders Mintlify projects unmodified.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:coverage": "bun run --filter '*' test -- --coverage --coverage.reporter=json-summary --coverage.reporter=text",
    "build": "bun run --filter '*' build",
    "check": "bun run format:check && bun run lint && bun run build && bun run typecheck",
    "ci": "bun run check && bun run test",
    "lint:deps": "knip",
    "lint:deps:fix": "knip --fix --allow-remove-files=false",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev:docs": "cd docs && ../packages/tangly/bin/tangly.js dev --no-open --port 4322",
    "build:docs": "cd docs && ../packages/tangly/bin/tangly.js build --out ./dist",
    "dev:opennem": "cd examples/opennem && ../../packages/tangly/bin/tangly.js dev --no-open --port 4321",
    "changeset": "changeset",
    "version": "changeset version && bun run scripts/sync-skill-versions.ts && bun install --lockfile-only",
    "release": "bun run build && changeset publish",
    "changelog:draft": "bun run scripts/draft-changelog.ts"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "piccolore": "^0.1.3",
    "unist-util-visit-parents": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "latest",
    "@vitest/coverage-v8": "^4",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-string": "^3.0.1",
    "hastscript": "^9.0.1",
    "knip": "^6.11.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "rehype": "^13.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^5.7.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "vitest": "^4"
  },
  "overrides": {
    "vite": "^7.3.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.11"
}
